@model FollowListViewModel
@{
    ViewData["Title"] = Model.ListTitle;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<section class="groove-app-page social-profile-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-teal">@Model.ListTitle</span>
            <h1>@Model.ProfileName</h1>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Details" asp-route-id="@Model.ProfileId" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> Back to profile
            </a>
        </div>
    </div>

    <div class="social-profile-list">
        @if (!Model.Profiles.Any())
        {
            <div class="social-empty-panel">
                <i class="bi bi-people"></i>
                <span>No profiles here yet.</span>
            </div>
        }
        else
        {
            @foreach (var profile in Model.Profiles)
            {
                var initial = string.IsNullOrWhiteSpace(profile.DisplayName) ? "?" : profile.DisplayName[..1].ToUpperInvariant();
                <article class="social-profile-row social-profile-row--large">
                    <a asp-action="Details" asp-route-id="@profile.Id" class="social-profile-row__main">
                        @if (!string.IsNullOrWhiteSpace(profile.ProfileImageUrl))
                        {
                            <img src="@profile.ProfileImageUrl" alt="@profile.DisplayName" />
                        }
                        else
                        {
                            <span>@initial</span>
                        }
                        <div>
                            <strong>@profile.DisplayName</strong>
                            <small>@(profile.IsOrganizer ? "Organizer" : "User") · @profile.FollowersCount followers · @profile.PostsCount posts</small>
                        </div>
                    </a>
                    @if (User.Identity?.IsAuthenticated == true && !profile.CurrentUserFollows)
                    {
                        <form asp-action="Follow" asp-route-id="@profile.Id" asp-route-returnUrl="@returnUrl" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-primary">Follow</button>
                        </form>
                    }
                </article>
            }
        }
    </div>
</section>
