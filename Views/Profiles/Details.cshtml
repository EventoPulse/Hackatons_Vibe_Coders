@model PublicProfileViewModel
@{
    ViewData["Title"] = Model.DisplayName;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var initial = string.IsNullOrWhiteSpace(Model.DisplayName) ? "?" : Model.DisplayName[..1].ToUpperInvariant();
}

<section class="groove-app-page social-profile-page">
    <article class="social-profile-hero">
        <div class="social-profile-hero__avatar">
            @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl))
            {
                <img src="@Model.ProfileImageUrl" alt="@Model.DisplayName" />
            }
            else
            {
                <span>@initial</span>
            }
        </div>
        <div class="social-profile-hero__body">
            <span class="groove-stamp @(Model.IsOrganizer ? "groove-stamp-teal" : "groove-stamp-red")" data-i18n="@(Model.IsOrganizer ? "profile.type.organizer" : "profile.type.profile")">
                @(Model.IsOrganizer ? "Organizer" : "Profile")
            </span>
            <h1>@Model.DisplayName</h1>
            @if (!string.IsNullOrWhiteSpace(Model.UserName))
            {
                <p class="social-profile-username">@@@Model.UserName</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Bio))
            {
                <p>@Model.Bio</p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Website))
            {
                <a href="@Model.Website" target="_blank" rel="noopener" class="groove-link">
                    <i class="bi bi-box-arrow-up-right"></i> <span data-i18n="profile.website">Website</span>
                </a>
            }
            <div class="social-profile-stats">
                <a asp-action="Followers" asp-route-id="@Model.Id"><strong>@Model.FollowersCount</strong><span data-i18n="profile.followers">followers</span></a>
                <a asp-action="Following" asp-route-id="@Model.Id"><strong>@Model.FollowingCount</strong><span data-i18n="profile.following">following</span></a>
                <span><strong>@Model.PostsCount</strong><span data-i18n="profile.posts">posts</span></span>
                <span><strong>@Model.EventsCount</strong><span data-i18n="profile.events">events</span></span>
            </div>
            <div class="groove-cta-row">
                @if (User.Identity?.IsAuthenticated == true && !Model.IsCurrentUser)
                {
                    if (Model.CurrentUserFollows)
                    {
                        <form asp-action="Unfollow" asp-route-id="@Model.Id" asp-route-returnUrl="@returnUrl" method="post">
                            @Html.AntiForgeryToken()
                            <button class="groove-button groove-button-paper" type="submit">
                                <i class="bi bi-person-dash"></i> <span data-i18n="profile.unfollow">Unfollow</span>
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="Follow" asp-route-id="@Model.Id" asp-route-returnUrl="@returnUrl" method="post">
                            @Html.AntiForgeryToken()
                            <button class="groove-button groove-button-dark" type="submit">
                                <i class="bi bi-person-plus"></i> <span data-i18n="profile.follow">Follow</span>
                            </button>
                        </form>
                    }

                    <form asp-controller="Messages" asp-action="Start" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@Model.Id" />
                        <button class="groove-button groove-button-paper" type="submit">
                            <i class="bi bi-chat-dots"></i> <span data-i18n="profile.message">Message</span>
                        </button>
                    </form>
                }
                else if (Model.IsCurrentUser)
                {
                    <a asp-controller="Account" asp-action="EditProfile" class="groove-button groove-button-dark">
                        <i class="bi bi-person-gear"></i> <span data-i18n="profile.edit">Edit profile</span>
                    </a>
                }
            </div>
        </div>
    </article>

    @if (Model.Events.Any())
    {
        <section class="groove-page-section">
            <div class="groove-section-bar">
                <div>
                    <span class="groove-kicker" data-i18n="profile.events.kicker">Events</span>
                    <h2 data-i18n-html="profile.events.title">Upcoming and past <span>events</span>.</h2>
                </div>
            </div>
            <div class="social-card-grid">
                @foreach (var ev in Model.Events)
                {
                    <partial name="_EventCard" model="ev" />
                }
            </div>
        </section>
    }

    <section class="groove-page-section">
        <div class="groove-section-bar">
            <div>
                <span class="groove-kicker" data-i18n="profile.posts.kicker">Posts</span>
                <h2 data-i18n-html="profile.posts.title">Latest <span>posts</span>.</h2>
            </div>
        </div>
        @if (Model.Posts.Any())
        {
            <div class="social-post-list">
                @foreach (var post in Model.Posts)
                {
                    <partial name="_PostCard" model="post" />
                }
            </div>
        }
        else
        {
            <div class="social-empty-panel">
                <i class="bi bi-journal-text"></i>
                <span data-i18n="profile.no.posts">No posts yet.</span>
            </div>
        }
    </section>
</section>
