@model EventsApp.ViewModels.Search.SearchResultsViewModel
@{
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.Query) ? "Search" : $"Search: {Model.Query}";
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <h1 class="h4 mb-3"><i class="bi bi-search"></i> Smart search</h1>
        <form asp-action="Index" method="get" class="row g-2">
            <div class="col-12 col-md">
                <input type="text" name="q" value="@Model.Query" class="form-control form-control-lg" placeholder="Try: rock, jazz, sofia, festival…" autofocus />
            </div>
            <div class="col-12 col-md-auto">
                <button class="btn btn-primary btn-lg w-100" type="submit"><i class="bi bi-stars"></i> Search</button>
            </div>
        </form>
        @if (!string.IsNullOrWhiteSpace(Model.AiHint))
        {
            <div class="alert alert-info mt-3 mb-0 small d-flex align-items-center">
                <i class="bi bi-robot me-2"></i><span>@Model.AiHint</span>
            </div>
        }
    </div>
</div>

@if (string.IsNullOrWhiteSpace(Model.Query))
{
    <div class="empty-state">Type a keyword to search events, venues and posts.</div>
}
else
{
    <section class="mb-4">
        <h2 class="h5"><i class="bi bi-calendar2-event"></i> Events (@Model.Events.Count)</h2>
        @if (Model.Events.Count == 0)
        {
            <p class="text-muted small mb-0">No matching events.</p>
        }
        else
        {
            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
                @foreach (var ev in Model.Events)
                {
                    <div class="col"><partial name="_EventCard" model="ev" /></div>
                }
            </div>
        }
    </section>

    <section class="mb-4">
        <h2 class="h5"><i class="bi bi-geo-alt"></i> Venues (@Model.Venues.Count)</h2>
        @if (Model.Venues.Count == 0)
        {
            <p class="text-muted small mb-0">No matching venues.</p>
        }
        else
        {
            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
                @foreach (var v in Model.Venues)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm">
                            @if (!string.IsNullOrWhiteSpace(v.ImageUrl))
                            {
                                <img src="@v.ImageUrl" class="card-img-top card-img-top-fixed" alt="@v.Name" />
                            }
                            <div class="card-body">
                                <h5 class="card-title">@v.Name</h5>
                                <p class="text-muted mb-1 small"><i class="bi bi-geo-alt"></i> @v.Address, @v.City</p>
                                <p class="text-muted small">@v.EventsCount events</p>
                                <a asp-controller="Venues" asp-action="Details" asp-route-id="@v.Id" class="btn btn-sm btn-outline-primary">Details</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <section class="mb-4">
        <h2 class="h5"><i class="bi bi-chat-square-text"></i> Posts (@Model.Posts.Count)</h2>
        @if (Model.Posts.Count == 0)
        {
            <p class="text-muted small mb-0">No matching posts.</p>
        }
        else
        {
            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
                @foreach (var p in Model.Posts)
                {
                    <div class="col"><partial name="_PostCard" model="p" /></div>
                }
            </div>
        }
    </section>
}
