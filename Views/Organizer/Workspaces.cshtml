@model IReadOnlyList<BusinessWorkspace>
@{
    ViewData["Title"] = "Business workspaces";
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-teal" data-i18n="workspace.title">Business workspaces</span>
            <h1><span data-i18n="workspace.h1">Legal and payment entities</span>.</h1>
            <p data-i18n="workspace.desc">Each public organizer page belongs to a workspace. Ticket sales are reported and paid to the workspace connected to that page.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Workspace" class="groove-button groove-button-dark">
                <i class="bi bi-building-add"></i> <span data-i18n="workspace.new">New workspace</span>
            </a>
            <a asp-action="Dashboard" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> <span data-i18n="nav.organizer.panel">Organizer Panel</span>
            </a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="groove-empty-card">
            <i class="bi bi-building"></i>
            <h2 data-i18n="workspace.empty.h">No workspaces yet.</h2>
            <p data-i18n="workspace.empty.p">Create a workspace before creating public organizer pages and selling tickets.</p>
            <a asp-action="Workspace" class="groove-button groove-button-dark" data-i18n="workspace.new">New workspace</a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-xl-4">
                    <article class="groove-table-card h-100" style="padding:1rem;">
                        <div class="d-flex justify-content-between gap-2">
                            <div>
                                <h2 class="h5 mb-1">@item.DisplayName</h2>
                                <p class="text-muted small mb-2">@item.LegalName</p>
                            </div>
                            @if (item.IsDefault)
                            {
                                <span class="groove-status-badge groove-status-badge-success" data-i18n="workspace.default">Default</span>
                            }
                        </div>
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            @if (!string.IsNullOrWhiteSpace(item.CompanyNumber))
                            {
                                <span class="groove-badge">@item.CompanyNumber</span>
                            }
                            <span class="groove-badge">@item.PaymentProvider</span>
                            <span class="groove-badge">@item.StripeOnboardingStatus</span>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <a asp-action="Workspace" asp-route-id="@item.Id" class="groove-button groove-button-paper">
                                <i class="bi bi-pencil-square"></i> <span data-i18n="common.edit">Edit</span>
                            </a>
                            <form asp-action="DeleteWorkspace" asp-route-id="@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="groove-button groove-button-paper text-danger"
                                        @(Model.Count <= 1 ? "disabled" : null)
                                        data-confirm-key="workspace.delete.confirm">
                                    <i class="bi bi-trash"></i> <span data-i18n="workspace.delete">Delete</span>
                                </button>
                            </form>
                        </div>
                        @if (Model.Count <= 1)
                        {
                            <p class="small text-muted mt-2 mb-0" data-i18n="workspace.delete.last">Create another workspace before deleting this one.</p>
                        }
                    </article>
                </div>
            }
        </div>
    }
</section>
