@model OrganizerDashboardViewModel
@using System.Globalization
@using System.Text.Json
@{
    ViewData["Title"] = "Организатор";
    var isEn = CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "en";
    var bgnFmt = (decimal v) => v.ToString("N2", CultureInfo.GetCultureInfo("bg-BG")) + " лв.";
    var salesPayload = new
    {
        labels = Model.SalesLast30Days.Select(p => p.Date.ToString("dd.MM")).ToArray(),
        sold = Model.SalesLast30Days.Select(p => p.Sold).ToArray(),
        revenue = Model.SalesLast30Days.Select(p => (double)p.Revenue).ToArray(),
    };
    var genrePayload = new
    {
        labels = Model.GenreBreakdown.Select(g => g.Genre.ToString()).ToArray(),
        counts = Model.GenreBreakdown.Select(g => g.Count).ToArray(),
    };
    var jsonOpts = new JsonSerializerOptions(JsonSerializerDefaults.Web);
    var salesJson = JsonSerializer.Serialize(salesPayload, jsonOpts);
    var genreJson = JsonSerializer.Serialize(genrePayload, jsonOpts);
    var maxGenreCount = Model.GenreBreakdown.Count > 0 ? Model.GenreBreakdown.Max(g => g.Count) : 1;
    var maxTopSold = Model.TopByTicketsSold.Count > 0 ? Model.TopByTicketsSold.Max(t => t.Sold) : 1;
    var maxTopRev = Model.TopByRevenue.Count > 0 ? Model.TopByRevenue.Max(t => t.Revenue) : 1m;
    var maxCityCount = Model.CityBreakdown.Count > 0 ? Model.CityBreakdown.Max(c => c.Count) : 1;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<section class="groove-app-page">
    @if (!Model.HasProfile)
    {
        <div class="groove-empty-card">
            <i class="bi bi-person-badge"></i>
            <h1 class="groove-panel-title" data-i18n-html="org.setup.h1">Нека подредим твоя <span>организаторски профил</span>.</h1>
            <p class="groove-panel-intro" data-i18n="org.setup.p">
                Добави име на организация, описание и контакти, за да започнеш да публикуваш събития и билети.
            </p>
            <div class="groove-form-actions justify-content-center">
                <a asp-action="Profile" class="groove-button groove-button-dark">
                    <i class="bi bi-pencil-square"></i> <span data-i18n="org.setup.btn">Попълни профила</span>
                </a>
                <a asp-action="Workspaces" class="groove-button groove-button-paper">
                    <i class="bi bi-building"></i> <span data-i18n="workspace.title">Business workspaces</span>
                </a>
                <a asp-action="Workspaces" class="groove-button groove-button-paper">
                    <i class="bi bi-building"></i> <span data-i18n="workspace.title">Workspaces</span>
                </a>
                <a asp-action="Workspace" class="groove-button groove-button-paper">
                    <i class="bi bi-building-add"></i> <span data-i18n="workspace.new">New workspace</span>
                </a>
                @if (!string.IsNullOrWhiteSpace(currentUserId))
                {
                    <a asp-controller="Profiles" asp-action="Details" asp-route-id="@currentUserId" class="groove-button groove-button-paper">
                        <i class="bi bi-person-lines-fill"></i> Public profile
                    </a>
                }
            </div>
        </div>
    }
    else
    {
        var approvalClass = Model.Approved ? "groove-status-badge-success" : "groove-status-badge-warning groove-status-badge-pending";
        var hasOrganizerPage = Model.ActivePageId.HasValue || Model.Pages.Any();
        var hasEvent = Model.EventsCount > 0;
        var hasTickets = Model.TicketTypesCount > 0;
        var hasBoostReady = Model.VipBoostCreditsAvailable > 0;

        <div class="groove-page-hero">
            <div class="groove-page-hero__copy">
                <span class="groove-stamp groove-stamp-teal" data-i18n="nav.organizer">Организатор</span>
                <h1>@Model.OrganizationName</h1>
                <p>@(!string.IsNullOrWhiteSpace(Model.Description)
                    ? Model.Description
                    : (isEn ? "This is your dashboard for events, posts, tickets and entry validation." : "Това е твоето работно табло за събития, публикации, билети и входна проверка."))</p>
                <div class="groove-inline-actions mt-3">
                    <span class="groove-status-badge @approvalClass">
                        @if (Model.Approved)
                        {
                            <span data-i18n="org.approved">Одобрен профил</span>
                        }
                        else
                        {
                            <span data-i18n="org.pending">Чака одобрение</span>
                        }
                    </span>
                    @if (!string.IsNullOrWhiteSpace(Model.PhoneNumber))
                    {
                        <span class="groove-badge"><i class="bi bi-telephone"></i> @Model.PhoneNumber</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Website))
                    {
                        <a href="@Model.Website" target="_blank" rel="noopener" class="groove-link" data-i18n="org.website">Уебсайт</a>
                    }
                </div>
            </div>

            <div class="groove-page-actions">
                <a asp-controller="Events" asp-action="Create" class="groove-button groove-button-dark">
                    <i class="bi bi-calendar-plus"></i> <span data-i18n="org.newevent">Ново събитие</span>
                </a>
                <a asp-controller="Posts" asp-action="Create" class="groove-button groove-button-paper">
                    <i class="bi bi-pencil-square"></i> <span data-i18n="org.newpost">Нова публикация</span>
                </a>
                <a asp-controller="Layouts" asp-action="Index" class="groove-button groove-button-paper">
                    <i class="bi bi-grid-3x3-gap"></i> <span data-i18n="layout.my">Моите layout-и</span>
                </a>
                <a asp-action="Profile" class="groove-button groove-button-paper">
                    <i class="bi bi-person-gear"></i> <span data-i18n="org.editprofile">Редактирай профила</span>
                </a>
                @if (!string.IsNullOrWhiteSpace(currentUserId))
                {
                    <a asp-controller="Profiles" asp-action="Details" asp-route-id="@currentUserId" class="groove-button groove-button-paper">
                        <i class="bi bi-person-lines-fill"></i> Public profile
                    </a>
                }
                <button type="button" class="org-tour__help-btn" onclick="orgTourOpen()" title="Покажи ръководство">
                    <i class="bi bi-question-circle"></i> <span data-i18n="org.tour.help">? Помощ</span>
                </button>
            </div>
        </div>

        <section class="organizer-command-grid my-4" aria-label="Основни действия">
            <a asp-controller="Tickets" asp-action="Validate" class="organizer-command-card organizer-command-card--primary">
                <i class="bi bi-qr-code-scan"></i>
                <span>Валидиране</span>
                <strong>Сканирай QR на входа</strong>
            </a>
            <a href="#org-revenue" class="organizer-command-card">
                <i class="bi bi-cash-coin"></i>
                <span>Приходи</span>
                <strong>@bgnFmt(Model.TotalRevenue)</strong>
            </a>
            <a href="#org-tickets" class="organizer-command-card">
                <i class="bi bi-ticket-perforated"></i>
                <span>Билети</span>
                <strong>@Model.TicketsSoldCount продадени</strong>
            </a>
            <a href="#org-engagement" class="organizer-command-card">
                <i class="bi bi-bell"></i>
                <span>Ангажираност</span>
                <strong>@(Model.TotalLikes + Model.TotalComments) реакции</strong>
            </a>
            <a asp-action="Events" class="organizer-command-card">
                <i class="bi bi-calendar-event"></i>
                <span>Събития</span>
                <strong>@Model.EventsCount общо</strong>
            </a>
            <a asp-controller="Organizer" asp-action="Validators" class="organizer-command-card">
                <i class="bi bi-person-check"></i>
                <span>Валидатори</span>
                <strong>Достъп за екипа</strong>
            </a>
        </section>

        @if (Model.ShowFirstBoostNotice)
        {
            <section class="organizer-boost-celebration my-4">
                <div>
                    <span class="groove-kicker">Нов organizer boost</span>
                    <h2>Профилът ти е одобрен. Имаш 1 VIP boost за старт.</h2>
                    <p>Използвай го върху най-важното си събитие, за да се показва по-високо в Home и препоръките.</p>
                </div>
                <div class="organizer-boost-celebration__actions">
                    <a asp-action="Events" class="groove-button groove-button-dark">
                        <i class="bi bi-stars"></i> Избери събитие
                    </a>
                    <form asp-action="DismissFirstBoostNotice" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
                        <button type="submit" class="groove-button groove-button-paper">Разбрах</button>
                    </form>
                </div>
            </section>
        }

        <section class="organizer-help-grid my-4" aria-label="Помощ за организатора">
            <article class="organizer-help-card">
                <span class="groove-kicker">Първи стъпки</span>
                <h2>Публикувай без да се чудиш кое следва.</h2>
                <ul class="organizer-checklist">
                    <li class="@(hasOrganizerPage ? "is-done" : "")"><i class="bi @(hasOrganizerPage ? "bi-check-circle-fill" : "bi-circle")"></i> Public page</li>
                    <li class="@(hasEvent ? "is-done" : "")"><i class="bi @(hasEvent ? "bi-check-circle-fill" : "bi-circle")"></i> Първо събитие</li>
                    <li class="@(hasTickets ? "is-done" : "")"><i class="bi @(hasTickets ? "bi-check-circle-fill" : "bi-circle")"></i> Билети или free вход</li>
                    <li class="@(hasBoostReady ? "is-done" : "")"><i class="bi @(hasBoostReady ? "bi-stars" : "bi-circle")"></i> VIP boost готов</li>
                </ul>
            </article>
            <article class="organizer-help-card organizer-help-card--soft">
                <span class="groove-kicker">Съвет</span>
                <h2>Преди да пуснеш събитие</h2>
                <p>Провери снимка, public page, дати, билети и как изглежда страницата за потребителите. Ако редактираш вече одобрено събитие, старото остава видимо, докато admin одобри новите промени.</p>
                <div class="d-flex flex-wrap gap-2">
                    <a asp-controller="Events" asp-action="Create" class="groove-button groove-button-paper">
                        <i class="bi bi-calendar-plus"></i> Ново събитие
                    </a>
                    <a asp-action="Events" class="groove-button groove-button-paper">
                        <i class="bi bi-list-check"></i> Моите събития
                    </a>
                </div>
            </article>
        </section>

        <section class="groove-table-card my-4" style="padding:1rem;">
            <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                <div>
                    <span class="groove-kicker" data-i18n="workspace.active.context">Active publishing context</span>
                    <h2 class="h5 mb-2">@Model.ActiveWorkspaceName</h2>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="groove-badge"><i class="bi bi-building"></i> <span data-i18n="workspace.label">Workspace</span>: @Model.ActiveWorkspaceName</span>
                        <span class="groove-badge"><i class="bi bi-megaphone"></i> <span data-i18n="workspace.publish.as">Publishing as</span>: @Model.ActivePageName</span>
                        <span class="groove-badge"><i class="bi bi-credit-card"></i> <span data-i18n="workspace.payments.to">Payments go to</span>: @Model.ActiveWorkspaceName</span>
                        <span class="groove-status-badge groove-status-badge-warning">@Model.PaymentStatus</span>
                    </div>
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <a asp-action="Workspaces" class="groove-button groove-button-paper">
                            <i class="bi bi-building"></i> <span data-i18n="workspace.all">All workspaces</span>
                        </a>
                        <a asp-action="Workspace" class="groove-button groove-button-dark">
                            <i class="bi bi-building-add"></i> <span data-i18n="workspace.new">New workspace</span>
                        </a>
                    </div>
                </div>
                <form asp-action="SwitchContext" method="post" class="d-flex flex-column flex-md-row gap-2 align-items-md-end">
                    @Html.AntiForgeryToken()
                    <div>
                        <label class="form-label small mb-1" for="workspaceId" data-i18n="workspace.switch.workspace">Workspace</label>
                        <select id="workspaceId" name="workspaceId" class="form-select">
                            @foreach (var workspace in Model.Workspaces)
                            {
                                if (workspace.Id == Model.ActiveWorkspaceId)
                                {
                                    <option value="@workspace.Id" selected>@workspace.DisplayName</option>
                                }
                                else
                                {
                                    <option value="@workspace.Id">@workspace.DisplayName</option>
                                }
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label small mb-1" for="pageId" data-i18n="workspace.switch.page">Page</label>
                        <select id="pageId" name="pageId" class="form-select">
                            @foreach (var orgPage in Model.Pages)
                            {
                                if (orgPage.Id == Model.ActivePageId)
                                {
                                    <option value="@orgPage.Id" selected>@orgPage.DisplayName</option>
                                }
                                else
                                {
                                    <option value="@orgPage.Id">@orgPage.DisplayName</option>
                                }
                            }
                        </select>
                    </div>
                    <button type="submit" class="groove-button groove-button-dark">
                        <i class="bi bi-arrow-repeat"></i> <span data-i18n="workspace.switch.save">Switch</span>
                    </button>
                </form>
            </div>
        </section>

        <div class="groove-stat-grid">
            <a href="#org-revenue" class="groove-stat-card text-decoration-none text-reset">
                <span data-i18n="org.stat.revenue">Приходи (общо)</span>
                <strong>@bgnFmt(Model.TotalRevenue)</strong>
                <small class="text-muted"><span data-i18n="org.stat.avgticket">Среден билет:</span> @bgnFmt(Model.AverageTicketPrice)</small>
            </a>
            <a href="#org-tickets" class="groove-stat-card text-decoration-none text-reset">
                <span data-i18n="org.stat.sold">Продадени билети</span>
                <strong>@Model.TicketsSoldCount</strong>
                <small class="text-muted"><span data-i18n="org.stat.scanned">Сканирани:</span> @Model.TicketsUsedCount</small>
            </a>
            <a href="#org-revenue" class="groove-stat-card text-decoration-none text-reset">
                <span data-i18n="org.stat.last30">Последни 30 дни</span>
                <strong>@Model.Last30DaysSold <span data-i18n="org.stat.pcs">бр.</span></strong>
                <small class="text-muted">@bgnFmt(Model.Last30DaysRevenue)</small>
            </a>
            <a asp-action="Events" class="groove-stat-card text-decoration-none text-reset">
                <span data-i18n="org.stat.events">Събития</span>
                <strong>@Model.EventsCount</strong>
                <small class="text-muted">
                    <span data-i18n="org.stat.upcoming">Предстоящи:</span> @Model.UpcomingEventsCount
                    · <span data-i18n="org.stat.past">минали:</span> @Model.PastEventsCount
                </small>
            </a>
            <a href="#org-tickets" class="groove-stat-card text-decoration-none text-reset">
                <span data-i18n="org.stat.tickettypes">Видове билети</span>
                <strong>@Model.TicketTypesCount</strong>
                <small class="text-muted"><span data-i18n="org.stat.activeevents">Активни събития:</span> @Model.EventsWithTicketsCount</small>
            </a>
            <a href="#org-engagement" class="groove-stat-card text-decoration-none text-reset">
                <span data-i18n="org.stat.engagement">Ангажираност</span>
                <strong>@Model.TotalLikes <i class="bi bi-heart-fill text-danger"></i></strong>
                <small class="text-muted">
                    @Model.TotalComments <span data-i18n="org.stat.comments">коментара</span>
                    · @Model.PostsCount <span data-i18n="org.stat.posts">публикации</span>
                </small>
            </a>
        </div>

        <section class="groove-table-card my-4" style="padding:1rem;">
            <div class="row g-3">
                <div class="col-md-6">
                    <span class="groove-kicker">Гледания</span>
                    <h2 class="h5 mb-1">@Model.TotalViews общо</h2>
                    <p class="text-muted mb-0">@Model.Last30DaysViews гледания през последните 30 дни.</p>
                </div>
                <div class="col-md-6">
                    <span class="groove-kicker">VIP boost</span>
                    <h2 class="h5 mb-1">@Model.VipBoostCreditsAvailable налични</h2>
                    <p class="text-muted mb-0">@Model.VipBoostCreditsUsed използвани. Нов organizer започва с 1 free boost.</p>
                </div>
            </div>
        </section>

        <section class="groove-page-section" id="org-engagement">
            <div class="groove-section-bar">
                <div>
                    <span class="groove-kicker">Ангажираност</span>
                    <h2>Последни реакции и коментари.</h2>
                </div>
                <a asp-controller="Posts" asp-action="Index" class="groove-link">Към потока</a>
            </div>

            <div class="organizer-dashboard-split">
                <div class="groove-table-card organizer-activity-card">
                    @if (Model.RecentEngagement.Count == 0)
                    {
                        <div class="social-empty-inline">Още няма реакции към твоите събития.</div>
                    }
                    else
                    {
                        @foreach (var activity in Model.RecentEngagement)
                        {
                            var icon = activity.Type == "Коментар" ? "bi-chat-dots" : "bi-heart";
                            <a asp-controller="Events" asp-action="Details" asp-route-id="@activity.EventId" class="organizer-activity-item">
                                <i class="bi @icon"></i>
                                <span>
                                    <strong>@activity.ActorName</strong>
                                    @(activity.Type == "Коментар" ? "коментира" : "хареса")
                                    <em>@activity.EventTitle</em>
                                    @if (!string.IsNullOrWhiteSpace(activity.Text))
                                    {
                                        <small>@activity.Text</small>
                                    }
                                </span>
                                <time>@activity.CreatedAt.ToLocalTime().ToString("dd.MM HH:mm")</time>
                            </a>
                        }
                    }
                </div>

                <div class="groove-table-card organizer-activity-card">
                    <div class="organizer-mini-metric">
                        <span>Харесвания</span>
                        <strong>@Model.TotalLikes</strong>
                    </div>
                    <div class="organizer-mini-metric">
                        <span>Коментари</span>
                        <strong>@Model.TotalComments</strong>
                    </div>
                    <div class="organizer-mini-metric">
                        <span>Гледания</span>
                        <strong>@Model.TotalViews</strong>
                    </div>
                    <div class="organizer-mini-metric">
                        <span>Публикации</span>
                        <strong>@Model.PostsCount</strong>
                    </div>
                </div>
            </div>
        </section>

        <section class="groove-page-section" id="org-revenue">
            <div class="groove-section-bar">
                <div>
                    <span class="groove-kicker" data-i18n="org.kicker.stats">Статистики</span>
                    <h2 data-i18n-html="org.sales.h2">Продажби през <span>последните 30 дни</span>.</h2>
                </div>
            </div>

            <div class="groove-table-card" style="padding:1rem;">
                <canvas id="orgSalesChart" height="90"></canvas>
            </div>

            <div class="row g-3 mt-3">
                <div class="col-lg-6">
                    <div class="groove-table-card" style="padding:1rem;">
                        <h3 class="h6 mb-3" data-i18n="org.top5sold.h">Топ 5 събития (продадени билети)</h3>
                        @if (Model.TopByTicketsSold.Count == 0)
                        {
                            <p class="text-muted small mb-0" data-i18n="org.nosales">Все още няма продажби.</p>
                        }
                        else
                        {
                            <ul class="list-unstyled mb-0">
                                @foreach (var t in Model.TopByTicketsSold)
                                {
                                    var pct = maxTopSold > 0 ? (int)Math.Round(100.0 * t.Sold / maxTopSold) : 0;
                                    <li class="mb-2">
                                        <div class="d-flex justify-content-between small">
                                            <a asp-controller="Events" asp-action="Details" asp-route-id="@t.EventId" class="fw-semibold text-decoration-none">@t.Title</a>
                                            <span class="text-muted">@t.Sold <span data-i18n="org.stat.pcs">бр.</span> · @bgnFmt(t.Revenue)</span>
                                        </div>
                                        <div class="progress" style="height:6px;">
                                            <div class="progress-bar bg-primary" style="width:@(pct)%;"></div>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="groove-table-card" style="padding:1rem;">
                        <h3 class="h6 mb-3" data-i18n="org.top5rev.h">Топ 5 събития (приход)</h3>
                        @if (Model.TopByRevenue.Count == 0)
                        {
                            <p class="text-muted small mb-0" data-i18n="org.norevenue">Все още няма приходи.</p>
                        }
                        else
                        {
                            <ul class="list-unstyled mb-0">
                                @foreach (var t in Model.TopByRevenue)
                                {
                                    var pct = maxTopRev > 0 ? (int)Math.Round(100m * t.Revenue / maxTopRev) : 0;
                                    <li class="mb-2">
                                        <div class="d-flex justify-content-between small">
                                            <a asp-controller="Events" asp-action="Details" asp-route-id="@t.EventId" class="fw-semibold text-decoration-none">@t.Title</a>
                                            <span class="text-muted">@bgnFmt(t.Revenue) · @t.Sold <span data-i18n="org.stat.pcs">бр.</span></span>
                                        </div>
                                        <div class="progress" style="height:6px;">
                                            <div class="progress-bar bg-success" style="width:@(pct)%;"></div>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>

            @if (Model.TopByViews.Count > 0)
            {
                <div class="row g-3 mt-1">
                    <div class="col-12">
                        <div class="groove-table-card" style="padding:1rem;">
                            <h3 class="h6 mb-3">Топ събития по гледания</h3>
                            <ul class="list-unstyled mb-0">
                                @foreach (var t in Model.TopByViews)
                                {
                                    <li class="d-flex flex-wrap justify-content-between gap-2 py-2 border-bottom">
                                        <a asp-controller="Events" asp-action="Details" asp-route-id="@t.EventId" class="fw-semibold text-decoration-none">@t.Title</a>
                                        <span class="text-muted">@t.Views гледания · @t.UniqueViewers уникални</span>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            }

            <div class="row g-3 mt-1">
                <div class="col-lg-6">
                    <div class="groove-table-card" style="padding:1rem;">
                        <h3 class="h6 mb-3" data-i18n="org.genre.h">Разпределение по жанр</h3>
                        @if (Model.GenreBreakdown.Count == 0)
                        {
                            <p class="text-muted small mb-0" data-i18n="org.nopublished">Няма публикувани събития.</p>
                        }
                        else
                        {
                            <canvas id="orgGenreChart" height="180"></canvas>
                        }
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="groove-table-card" style="padding:1rem;">
                        <h3 class="h6 mb-3" data-i18n="org.cities.h">Събития по град</h3>
                        @if (Model.CityBreakdown.Count == 0)
                        {
                            <p class="text-muted small mb-0" data-i18n="org.nopublished">Няма публикувани събития.</p>
                        }
                        else
                        {
                            <ul class="list-unstyled mb-0">
                                @foreach (var c in Model.CityBreakdown)
                                {
                                    var pct = maxCityCount > 0 ? (int)Math.Round(100.0 * c.Count / maxCityCount) : 0;
                                    <li class="mb-2">
                                        <div class="d-flex justify-content-between small">
                                            <span class="fw-semibold">@c.City</span>
                                            <span class="text-muted">
                                                @c.Count @(isEn
                                                    ? (c.Count == 1 ? "event" : "events")
                                                    : (c.Count == 1 ? "събитие" : "събития"))
                                            </span>
                                        </div>
                                        <div class="progress" style="height:6px;">
                                            <div class="progress-bar" style="width:@(pct)%;background:#0f766e;"></div>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </section>

        <section class="groove-page-section" id="org-tickets">
            <div class="groove-section-bar">
                <div>
                    <span class="groove-kicker" data-i18n="org.kicker.sales">Продажби</span>
                    <h2 data-i18n-html="org.tickets.h2">Билети по <span>събития</span>.</h2>
                </div>
                <a asp-action="Events" class="groove-link">Всички събития</a>
            </div>

            @if (Model.EventTicketRows.Count == 0)
            {
                <div class="groove-table-card p-3">
                    <div class="social-empty-inline">Още няма събития с билети.</div>
                </div>
            }
            else
            {
                <div class="groove-table-card">
                    <div class="groove-table-wrap organizer-events-wrap">
                        <table class="table organizer-dashboard-table organizer-dashboard-table--events">
                            <thead>
                                <tr>
                                    <th data-i18n="org.th.event">Събитие</th>
                                    <th data-i18n="org.th.start">Начало</th>
                                    <th data-i18n="org.th.status">Статус</th>
                                    <th data-i18n="org.th.sold">Продадени</th>
                                    <th>Приходи</th>
                                    <th>Гледания</th>
                                    <th>VIP</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.EventTicketRows)
                                {
                                    <tr class="organizer-event-row">
                                        <td data-label="Събитие">
                                            <strong>@row.EventTitle</strong>
                                        </td>
                                        <td data-label="Начало">@row.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td data-label="Статус">
                                            @if (row.HasActiveTickets)
                                            {
                                                <span class="groove-status-badge groove-status-badge-success" data-i18n="org.badge.active">Активни билети</span>
                                            }
                                            else
                                            {
                                                <span class="groove-status-badge groove-status-badge-muted" data-i18n="org.badge.none">Без билети</span>
                                            }
                                        </td>
                                        <td data-label="Продадени">@row.Sold</td>
                                        <td data-label="Приходи">@bgnFmt(row.Revenue)</td>
                                        <td data-label="Гледания">
                                            <strong>@row.Views</strong>
                                            <span class="text-muted small d-block">@row.UniqueViewers уникални</span>
                                        </td>
                                        <td data-label="VIP">
                                            @if (row.VipBoostScore > 0)
                                            {
                                                <span class="evt-card__chip evt-card__chip--vip organizer-vip-badge" style="position:static;">VIP x@row.VipBoostScore</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">-</span>
                                            }
                                        </td>
                                        <td data-label="Действия">
                                            <div class="groove-list-actions">
                                                <a asp-controller="Events" asp-action="Edit" asp-route-id="@row.EventId" class="groove-button groove-button-paper">
                                                    <i class="bi bi-pencil"></i> <span data-i18n="org.btn.edit">Редакция</span>
                                                </a>
                                                <a asp-controller="Tickets" asp-action="Manage" asp-route-id="@row.EventId" class="groove-button groove-button-dark">
                                                    <i class="bi bi-ticket-perforated"></i> <span data-i18n="org.btn.tickets">Билети</span>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <div class="groove-table-card mt-3">
                <div class="groove-table-wrap organizer-events-wrap">
                    <table class="table organizer-dashboard-table organizer-dashboard-table--tickets">
                        <thead>
                            <tr>
                                <th>Билет</th>
                                <th>Купувач</th>
                                <th>Дата</th>
                                <th>Цена</th>
                                <th>Състояние</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.SoldTickets.Count == 0)
                            {
                                <tr>
                                    <td colspan="6" class="text-muted">Още няма продадени билети.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var ticket in Model.SoldTickets)
                                {
                                    <tr class="organizer-ticket-row">
                                        <td data-label="Билет">
                                            <strong>@ticket.EventTitle</strong>
                                            <span class="text-muted small d-block">@ticket.TicketName · @ticket.StartTime.ToString("dd.MM HH:mm")</span>
                                        </td>
                                        <td data-label="Купувач">
                                            @ticket.BuyerEmail
                                            @if (!string.IsNullOrWhiteSpace(ticket.AttendeeName))
                                            {
                                                <span class="text-muted small d-block">@ticket.AttendeeName</span>
                                            }
                                        </td>
                                        <td data-label="Дата">@ticket.PurchasedAt.ToLocalTime().ToString("dd.MM HH:mm")</td>
                                        <td data-label="Цена">@bgnFmt(ticket.PricePaid)</td>
                                        <td data-label="Състояние">
                                            <span class="groove-status-badge @(ticket.IsUsed ? "groove-status-badge-success" : "groove-status-badge-muted")">
                                                @(ticket.IsUsed ? "Валидиран" : "Неизползван")
                                            </span>
                                        </td>
                                        <td data-label="Действия">
                                            <a asp-controller="Tickets" asp-action="Details" asp-route-id="@ticket.Id" class="groove-button groove-button-paper">
                                                <i class="bi bi-eye"></i> Детайли
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        @if (Model.RecentEvents.Count > 0)
        {
            <section class="groove-page-section">
                <div class="groove-section-bar">
                    <div>
                        <span class="groove-kicker" data-i18n="org.kicker.catalog">Каталог</span>
                        <h2 data-i18n-html="org.recent.events.h2">Последни <span>събития</span>.</h2>
                    </div>
                </div>

                <div class="row row-cols-1 row-cols-sm-2 row-cols-xl-3 g-3">
                    @foreach (var ev in Model.RecentEvents)
                    {
                        <div class="col"><partial name="_EventCard" model="ev" /></div>
                    }
                </div>
            </section>
        }

        @if (Model.RecentPosts.Count > 0)
        {
            <section class="groove-page-section">
                <div class="groove-section-bar">
                    <div>
                        <span class="groove-kicker" data-i18n="org.kicker.diary">Дневник</span>
                        <h2 data-i18n-html="org.recent.posts.h2">Последни <span>публикации</span>.</h2>
                    </div>
                </div>

                <div class="row row-cols-1 row-cols-sm-2 row-cols-xl-3 g-3">
                    @foreach (var post in Model.RecentPosts)
                    {
                        <div class="col"><partial name="_PostCard" model="post" /></div>
                    }
                </div>
            </section>
        }
    }
</section>

@if (Model.HasProfile)
{
    <div id="org-tour" class="org-tour" style="display:none;" role="dialog" aria-modal="true" aria-label="Организаторски наръчник">
        <div class="org-tour__backdrop" onclick="orgTourClose()"></div>
        <div class="org-tour__dialog">
            <div class="org-tour__step is-active" data-step="1">
                <div class="org-tour__icon"><i class="bi bi-rocket-takeoff"></i></div>
                <h2 data-i18n="org.tour.step1.h">Добре дошъл в Organizer Panel!</h2>
                <p data-i18n="org.tour.step1.p">Тук управляваш публичните си идентичности, събития, билети и приходи — всичко от едно място.</p>
            </div>
            <div class="org-tour__step" data-step="2">
                <div class="org-tour__icon"><i class="bi bi-megaphone"></i></div>
                <h2 data-i18n="org.tour.step2.h">Публична страница</h2>
                <p data-i18n="org.tour.step2.p">Преди да публикуваш събитие, трябва да имаш поне една публична страница. Тя е лицето ти — хората я виждат при всяко събитие.</p>
                <a asp-action="Profiles" class="org-tour__link">Публични страници →</a>
            </div>
            <div class="org-tour__step" data-step="3">
                <div class="org-tour__icon"><i class="bi bi-calendar-plus"></i></div>
                <h2 data-i18n="org.tour.step3.h">Публикувай събитие</h2>
                <p data-i18n="org.tour.step3.p">Натисни "Ново събитие" и добави снимка, дати, жанр и локация. Събитието влиза за одобрение от admin, след което е видимо за всички.</p>
                <a asp-controller="Events" asp-action="Create" class="org-tour__link">Ново събитие →</a>
            </div>
            <div class="org-tour__step" data-step="4">
                <div class="org-tour__icon"><i class="bi bi-ticket-perforated"></i></div>
                <h2 data-i18n="org.tour.step4.h">Билети и приходи</h2>
                <p data-i18n="org.tour.step4.p">Добавяй различни типове билети — безплатни, платени или VIP. Продажбата се случва директно от страницата на събитието.</p>
                <a asp-action="Events" class="org-tour__link">Моите събития →</a>
            </div>
            <div class="org-tour__step" data-step="5">
                <div class="org-tour__icon"><i class="bi bi-bar-chart-line"></i></div>
                <h2 data-i18n="org.tour.step5.h">Статистики и VIP Boost</h2>
                <p data-i18n="org.tour.step5.p">Следи продажбите, гледанията и ангажираността. Нов организатор получава 1 VIP boost — постави го на събитието, което искаш да промотираш най-много.</p>
            </div>
            <div class="org-tour__dots">
                <span class="org-tour__dot is-active"></span>
                <span class="org-tour__dot"></span>
                <span class="org-tour__dot"></span>
                <span class="org-tour__dot"></span>
                <span class="org-tour__dot"></span>
            </div>
            <div class="org-tour__actions">
                <button type="button" class="org-tour__skip" onclick="orgTourClose()" data-i18n="org.tour.skip">Пропусни</button>
                <button type="button" class="org-tour__next" id="org-tour-next-btn" onclick="orgTourNext()" data-i18n="org.tour.next">Напред</button>
                <button type="button" class="org-tour__finish" id="org-tour-finish-btn" onclick="orgTourClose()" data-i18n="org.tour.finish" style="display:none;">Готово!</button>
            </div>
        </div>
    </div>
}

@section Scripts {
    @if (Model.HasProfile)
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
        <script>
            (function () {
                var sales = @Html.Raw(salesJson);
                var genre = @Html.Raw(genreJson);
                var isEn = (document.querySelector('meta[name="x-app-lang"]') || {}).content === 'en';

                var salesEl = document.getElementById('orgSalesChart');
                if (salesEl && window.Chart && sales && sales.labels) {
                    new Chart(salesEl, {
                        type: 'line',
                        data: {
                            labels: sales.labels,
                            datasets: [
                                {
                                    label: isEn ? 'Tickets Sold' : 'Продадени билети',
                                    data: sales.sold,
                                    borderColor: '#0f766e',
                                    backgroundColor: 'rgba(15,118,110,0.15)',
                                    tension: 0.3, fill: true, yAxisID: 'y'
                                },
                                {
                                    label: isEn ? 'Revenue (BGN)' : 'Приход (лв.)',
                                    data: sales.revenue,
                                    borderColor: '#dc2626',
                                    backgroundColor: 'rgba(220,38,38,0.10)',
                                    tension: 0.3, fill: false, yAxisID: 'y1'
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            interaction: { mode: 'index', intersect: false },
                            plugins: { legend: { position: 'bottom' } },
                            scales: {
                                y: { beginAtZero: true, position: 'left', title: { display: true, text: isEn ? 'Tickets' : 'Билети' } },
                                y1: { beginAtZero: true, position: 'right', grid: { drawOnChartArea: false }, title: { display: true, text: isEn ? 'BGN' : 'лв.' } }
                            }
                        }
                    });
                }

                var genreEl = document.getElementById('orgGenreChart');
                if (genreEl && window.Chart && genre && genre.labels && genre.labels.length) {
                    new Chart(genreEl, {
                        type: 'doughnut',
                        data: {
                            labels: genre.labels,
                            datasets: [{
                                data: genre.counts,
                                backgroundColor: ['#0ea5e9', '#a855f7', '#f59e0b', '#ec4899', '#dc2626', '#7c3aed', '#14b8a6', '#0f766e'],
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            plugins: { legend: { position: 'bottom' } }
                        }
                    });
                }
            })();
        </script>
    }

    @if (Model.HasProfile)
    {
        <script>
            var orgTourStep = 1;
            var orgTourTotal = 5;

            function orgTourOpen() {
                orgTourStep = 1;
                orgTourRender();
                document.getElementById('org-tour').style.display = 'flex';
                document.body.style.overflow = 'hidden';
            }

            function orgTourClose() {
                document.getElementById('org-tour').style.display = 'none';
                document.body.style.overflow = '';
                try { localStorage.setItem('org_tour_seen', '1'); } catch (_) {}
            }

            function orgTourNext() {
                if (orgTourStep < orgTourTotal) {
                    orgTourStep++;
                    orgTourRender();
                }
            }

            function orgTourRender() {
                var steps = document.querySelectorAll('#org-tour .org-tour__step');
                var dots = document.querySelectorAll('#org-tour .org-tour__dot');
                var nextBtn = document.getElementById('org-tour-next-btn');
                var finishBtn = document.getElementById('org-tour-finish-btn');
                steps.forEach(function (s, i) {
                    s.classList.toggle('is-active', i + 1 === orgTourStep);
                });
                dots.forEach(function (d, i) {
                    d.classList.toggle('is-active', i + 1 === orgTourStep);
                });
                var isLast = orgTourStep === orgTourTotal;
                nextBtn.style.display = isLast ? 'none' : '';
                finishBtn.style.display = isLast ? '' : 'none';
            }

            document.addEventListener('DOMContentLoaded', function () {
                try {
                    if (!localStorage.getItem('org_tour_seen')) {
                        setTimeout(orgTourOpen, 600);
                    }
                } catch (_) {}
            });
        </script>
    }
}
