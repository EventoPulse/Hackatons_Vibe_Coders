@model OrganizerValidatorsViewModel
@{
    ViewData["Title"] = "Валидатори";
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-yellow">Контрол на билети</span>
            <h1>Достъп за валидатори.</h1>
            <p>
                Добави до 3 служебни акаунта, които могат да сканират билети за избрана публична страница.
                Валидаторите не виждат лични данни за организатора и нямат достъп до организаторския панел.
            </p>
        </div>
        <div class="groove-page-actions">
            <a asp-controller="Organizer" asp-action="Dashboard" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> Табло
            </a>
            <a asp-controller="Tickets" asp-action="Validate" class="groove-button groove-button-dark">
                <i class="bi bi-qr-code-scan"></i> Валидирай билети
            </a>
        </div>
    </div>

    <div class="groove-split">
        <div class="groove-form-panel groove-highlight-card">
            <span class="groove-kicker">Добави валидатор</span>
            <h2 class="groove-panel-title">Служебен акаунт.</h2>
            <p class="groove-panel-intro">
                Първо създай обикновен потребителски акаунт на служебния телефон, после го добави тук по имейл, username или телефон.
                Активни валидатори общо: @Model.ActiveValidatorsCount. Лимитът е @Model.MaxValidators за всяка публична страница.
            </p>

            @if (Model.Pages.Count == 0)
            {
                <div class="alert alert-info">Създай публична страница, за да можеш да добавиш валидатор.</div>
            }
            else
            {
                <form asp-action="AddValidator" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label" for="validatorLookup">Имейл, потребителско име или телефон</label>
                        <input id="validatorLookup" name="UserLookup" class="form-control" autocomplete="off" placeholder="validator@evento.app" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="validatorPage">Публична страница</label>
                        <select id="validatorPage" name="OrganizerProfileId" class="form-select">
                            @foreach (var option in Model.Pages)
                            {
                                <option value="@option.Id" selected="@option.IsDefault">@option.DisplayName</option>
                            }
                        </select>
                        <small class="text-muted">Валидаторът ще може да сканира билети за всички събития, публикувани от тази страница.</small>
                    </div>

                    <button type="submit" class="groove-button groove-button-dark">
                        <i class="bi bi-person-check"></i> Добави валидатор
                    </button>
                </form>
            }
        </div>

        <div class="groove-info-card">
            <span class="groove-kicker">Правила</span>
            <h2 class="groove-panel-title">Ограничен достъп.</h2>
            <ul class="mb-0">
                <li>До 3 активни валидатора за организатор.</li>
                <li>Валидаторът важи за цялата публична страница.</li>
                <li>Може да сканира всички събития, публикувани от тази страница.</li>
                <li>Не вижда кой е реалният собственик на страницата.</li>
                <li>Ползвай отделни служебни акаунти за телефоните на входа.</li>
            </ul>
        </div>
    </div>

    <section class="groove-page-section">
        <div class="groove-section-bar">
            <div>
                <span class="groove-kicker">Текущи валидатори</span>
                <h2>Хора, които могат да сканират.</h2>
            </div>
        </div>

        @if (Model.Validators.Count == 0)
        {
            <div class="groove-empty-state">Още няма добавени валидатори.</div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var validator in Model.Validators)
                {
                    <div class="col-12 col-lg-6">
                        <div class="groove-info-card h-100">
                            <div class="d-flex justify-content-between gap-3 align-items-start">
                                <div>
                                    <span class="groove-status-badge @(validator.IsActive ? "groove-status-badge-success" : "groove-status-badge-muted")">
                                        @(validator.IsActive ? "Активен" : "Неактивен")
                                    </span>
                                    <h3 class="mt-3 mb-1">@validator.DisplayName</h3>
                                    @if (!string.IsNullOrWhiteSpace(validator.Email))
                                    {
                                        <p class="text-muted small mb-0">@validator.Email</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(validator.PhoneNumber))
                                    {
                                        <p class="text-muted small mb-0">@validator.PhoneNumber</p>
                                    }
                                    <p class="text-muted small mt-2 mb-0">
                                        Страница: <strong>@(validator.OrganizerProfileName ?? "не е избрана")</strong>
                                    </p>
                                </div>
                                <form asp-action="RemoveValidator" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@validator.Id" />
                                    <button type="submit" class="groove-button groove-button-paper">
                                        <i class="bi bi-x-circle"></i> Премахни
                                    </button>
                                </form>
                            </div>

                            <form asp-action="UpdateValidatorPage" method="post" class="mt-4">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@validator.Id" />
                                <label class="form-label" for="page-@validator.Id">Публична страница</label>
                                <select id="page-@validator.Id" name="organizerProfileId" class="form-select">
                                    @foreach (var option in Model.Pages)
                                    {
                                        <option value="@option.Id" selected="@(option.Id == validator.OrganizerProfileId)">@option.DisplayName</option>
                                    }
                                </select>
                                <button type="submit" class="groove-button groove-button-dark mt-3">
                                    <i class="bi bi-save"></i> Запази достъпа
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </section>
</section>
