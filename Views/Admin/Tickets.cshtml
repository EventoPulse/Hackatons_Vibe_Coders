@model AdminTicketsViewModel
@{
    ViewData["Title"] = "Билети";
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-teal" data-i18n="admin.kicker.sales">Продажби</span>
            <h1 data-i18n-html="admin.tickets.title">Обзор на <span>билетите</span>.</h1>
            <p data-i18n="admin.tickets.desc">Следи активните типове билети, продажбите, използваните входове и демонстрационния приход.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> <span data-i18n="common.back.admin">Към админ</span>
            </a>
        </div>
    </div>

    <div class="groove-stat-grid">
        <article class="groove-stat-card">
            <span data-i18n="admin.stat.ticket.types">Типове билети</span>
            <strong>@Model.TicketTypesCount</strong>
        </article>
        <article class="groove-stat-card">
            <span data-i18n="admin.stat.sold">Продадени</span>
            <strong>@Model.TicketsSoldCount</strong>
        </article>
        <article class="groove-stat-card">
            <span data-i18n="admin.stat.used">Използвани</span>
            <strong>@Model.UsedTicketsCount</strong>
        </article>
        <article class="groove-stat-card">
            <span data-i18n="admin.stat.remaining">Оставащи</span>
            <strong>@Model.UnusedTicketsCount</strong>
        </article>
        <article class="groove-stat-card">
            <span data-i18n="admin.stat.revenue">Приход</span>
            <strong>@Model.TotalRevenue.ToString("0.00")</strong>
        </article>
    </div>

    <section class="groove-page-section">
        <div class="groove-section-bar">
            <div>
                <span class="groove-kicker" data-i18n="admin.tickets.latest.purchases">Последни покупки</span>
                <h2 data-i18n-html="admin.tickets.recent.motion">Скорошно <span>движение</span>.</h2>
            </div>
        </div>

        @if (Model.Recent.Count == 0)
        {
            <div class="groove-empty-card">
                <i class="bi bi-ticket-perforated"></i>
                <h2 class="groove-panel-title" data-i18n-html="admin.tickets.empty.title">Все още няма <span>покупки</span>.</h2>
            </div>
        }
        else
        {
            <div class="groove-table-card">
                <div class="groove-table-wrap">
                    <table class="table">
                        <thead>
                            <tr>
                                <th data-i18n="admin.table.event">Събитие</th>
                                <th data-i18n="admin.table.ticket">Билет</th>
                                <th data-i18n="admin.table.owner">Притежател</th>
                                <th data-i18n="admin.table.price">Цена</th>
                                <th data-i18n="admin.table.purchased">Купен</th>
                                <th data-i18n="admin.table.status">Статус</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.Recent)
                            {
                                var statusClass = t.IsUsed ? "admin-badge--status-used" : "admin-badge--status-valid";
                                var statusKey = t.IsUsed ? "ticket.status.used" : "ticket.status.valid";
                                var statusText = t.IsUsed ? "Използван" : "Валиден";

                                <tr>
                                    <td><strong>@t.EventTitle</strong></td>
                                    <td>@t.TicketName</td>
                                    <td>@t.OwnerUserName</td>
                                    <td>@t.Price.ToTicketPriceDisplay()</td>
                                    <td>@t.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td><span class="admin-badge @statusClass" data-i18n="@statusKey">@statusText</span></td>
                                    <td>
                                        <a asp-controller="Tickets" asp-action="Details" asp-route-id="@t.Id" class="groove-button groove-button-paper">
                                            <i class="bi bi-eye"></i> <span data-i18n="common.details">Детайли</span>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </section>
</section>
