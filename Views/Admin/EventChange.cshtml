@model EventChangeReviewViewModel
@{
    ViewData["Title"] = "Преглед на промени";
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-yellow">Админ преглед</span>
            <h1>Промени по събитие.</h1>
            <p>Публикуваната версия остава активна, докато тези промени не бъдат одобрени.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Events" asp-route-pending="true" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> Чакащи
            </a>
            <form asp-action="ApproveEvent" asp-route-id="@Model.EventId" method="post">
                @Html.AntiForgeryToken()
                <button class="groove-button groove-button-dark" type="submit">
                    <i class="bi bi-check-circle"></i> Одобри промени
                </button>
            </form>
        </div>
    </div>

    <div class="groove-split">
        <article class="groove-info-card">
            <span class="groove-kicker">Текуща версия</span>
            @if (!string.IsNullOrWhiteSpace(Model.CurrentImageUrl))
            {
                <img src="@Model.CurrentImageUrl" class="img-fluid rounded mb-3" alt="@Model.CurrentTitle" style="max-height:240px;width:100%;object-fit:cover;" />
            }
            <h2 class="groove-panel-title">@Model.CurrentTitle</h2>
            <dl class="groove-data-list mt-3">
                <dt>Локация</dt>
                <dd>@Model.CurrentAddress, @Model.CurrentCity</dd>
                <dt>Начало</dt>
                <dd>@Model.CurrentStartTime.ToString("dd.MM.yyyy HH:mm")</dd>
                <dt>Край</dt>
                <dd>@Model.CurrentEndTime.ToString("dd.MM.yyyy HH:mm")</dd>
                <dt>Жанр</dt>
                <dd>@Model.CurrentGenre.GetDisplayName()</dd>
            </dl>
        </article>

        <article class="groove-info-card">
            <span class="groove-kicker">Нова версия</span>
            @if (!string.IsNullOrWhiteSpace(Model.Pending.ImageUrl))
            {
                <img src="@Model.Pending.ImageUrl" class="img-fluid rounded mb-3" alt="@Model.Pending.Title" style="max-height:240px;width:100%;object-fit:cover;" />
            }
            <h2 class="groove-panel-title">@Model.Pending.Title</h2>
            <dl class="groove-data-list mt-3">
                <dt>Локация</dt>
                <dd>@Model.Pending.Address, @Model.Pending.City</dd>
                <dt>Начало</dt>
                <dd>@Model.Pending.StartTime.ToString("dd.MM.yyyy HH:mm")</dd>
                <dt>Край</dt>
                <dd>@Model.Pending.EndTime.ToString("dd.MM.yyyy HH:mm")</dd>
                <dt>Жанр</dt>
                <dd>@Model.Pending.Genre.GetDisplayName()</dd>
                <dt>Изпратено</dt>
                <dd>@Model.SubmittedAt.ToString("dd.MM.yyyy HH:mm")</dd>
            </dl>
        </article>
    </div>

    <section class="groove-page-section">
        <div class="groove-info-card">
            <span class="groove-kicker">Описание</span>
            <p class="mb-0">@Model.Pending.Description</p>
        </div>
    </section>
</section>
