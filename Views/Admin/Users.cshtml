@model IReadOnlyList<(EventsApp.Models.ApplicationUser User, IList<string> Roles)>
@{
    ViewData["Title"] = "Потребители";
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-yellow" data-i18n="admin.kicker.roles">Роли</span>
            <h1 data-i18n-html="admin.users.title">Управление на <span>потребители</span>.</h1>
            <p data-i18n="admin.users.desc">Променяй роли и редактирай профили от едно място.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> <span data-i18n="common.back.admin">Към админ</span>
            </a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="groove-empty-card">
            <i class="bi bi-people"></i>
            <h2 class="groove-panel-title" data-i18n-html="admin.users.empty.title">Няма <span>потребители</span>.</h2>
            <p class="groove-panel-intro" data-i18n="admin.users.empty.desc">След като се регистрират акаунти, ще се появят тук.</p>
        </div>
    }
    else
    {
        <div class="groove-table-card">
            <div class="groove-table-wrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th data-i18n="admin.table.user">Потребител</th>
                            <th data-i18n="admin.table.email">Имейл</th>
                            <th data-i18n="admin.table.current.role">Текуща роля</th>
                            <th data-i18n="admin.table.new.role">Нова роля</th>
                            <th data-i18n="admin.table.actions">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (user, roles) in Model)
                        {
                            var currentRole = roles.FirstOrDefault();
                            var roleKey = currentRole == GlobalConstants.Roles.Admin ? "role.admin"
                                : currentRole == GlobalConstants.Roles.Organizer ? "role.organizer"
                                : currentRole == GlobalConstants.Roles.User ? "role.user"
                                : "role.none";
                            var roleClass = currentRole == GlobalConstants.Roles.Admin ? "admin-badge--role-admin"
                                : currentRole == GlobalConstants.Roles.Organizer ? "admin-badge--role-organizer"
                                : "admin-badge--role-user";

                            <tr>
                                <td><strong>@user.UserName</strong></td>
                                <td>@user.Email</td>
                                <td><span class="admin-badge @roleClass" data-i18n="@roleKey">@currentRole.ToRoleDisplay()</span></td>
                                <td>
                                    <form asp-action="SetRole" method="post" class="d-flex flex-wrap gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <select name="role" class="form-select form-select-sm" style="max-width: 180px;">
                                            <option value="@GlobalConstants.Roles.User" selected="@(currentRole == GlobalConstants.Roles.User)" data-i18n="role.user">Потребител</option>
                                            <option value="@GlobalConstants.Roles.Organizer" selected="@(currentRole == GlobalConstants.Roles.Organizer)" data-i18n="role.organizer">Организатор</option>
                                            <option value="@GlobalConstants.Roles.Admin" selected="@(currentRole == GlobalConstants.Roles.Admin)" data-i18n="role.admin">Админ</option>
                                        </select>
                                        <button type="submit" class="groove-button groove-button-dark">
                                            <i class="bi bi-check2"></i> <span data-i18n="common.save">Запази</span>
                                        </button>
                                    </form>
                                </td>
                                <td>
                                    <form asp-action="DeleteUser" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="groove-button groove-button-paper text-danger" data-confirm-key="admin.users.delete.confirm">
                                            <i class="bi bi-trash"></i> <span data-i18n="common.delete">Изтрий</span>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
