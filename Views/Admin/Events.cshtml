@model IReadOnlyList<EventCardViewModel>
@{
    ViewData["Title"] = "Събития";
    var pendingOnly = (bool)(ViewBag.PendingOnly ?? false);
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-teal" data-i18n="admin.kicker.catalog">Каталог</span>
            <h1 data-i18n-html="admin.events.title">Админ преглед на <span>събития</span>.</h1>
            <p data-i18n="admin.events.desc">Одобрявай, редактирай и управлявай публикуваните събития и билетите към тях.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Events" asp-route-pending="@(!pendingOnly)" class="groove-button groove-button-paper">
                @if (pendingOnly)
                {
                    <text><i class="bi bi-list"></i> <span data-i18n="common.show.all">Покажи всички</span></text>
                }
                else
                {
                    <text><i class="bi bi-hourglass-split"></i> <span data-i18n="admin.events.pending.only">Само чакащи</span></text>
                }
            </a>
            <a asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> <span data-i18n="common.back.admin">Към админ</span>
            </a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="groove-empty-card">
            <i class="bi bi-calendar2-event"></i>
            <h2 class="groove-panel-title" data-i18n-html="admin.events.empty.title">Няма <span>събития</span>.</h2>
        </div>
    }
    else
    {
        <div class="groove-table-card">
            <div class="groove-table-wrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th data-i18n="admin.table.title">Заглавие</th>
                            <th data-i18n="admin.table.organizer">Организатор</th>
                            <th data-i18n="admin.table.location">Локация</th>
                            <th data-i18n="admin.table.start">Начало</th>
                            <th data-i18n="admin.table.genre">Жанр</th>
                            <th data-i18n="admin.table.status">Статус</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ev in Model)
                        {
                            <tr>
                                <td><strong>@ev.Title</strong></td>
                                <td>@ev.OrganizerName</td>
                                <td>@ev.Address, @ev.City</td>
                                <td>@ev.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                                <td><span class="admin-badge admin-badge--genre" data-i18n="@($"genre.{ev.Genre}")">@ev.Genre.GetDisplayName()</span></td>
                                <td>
                                    @if (ev.HasPendingChanges)
                                    {
                                        <span class="admin-badge admin-badge--status-pending" data-i18n="admin.status.pending.changes">Чака промени</span>
                                    }
                                    else if (ev.IsApproved)
                                    {
                                        <span class="admin-badge admin-badge--status-approved" data-i18n="admin.status.approved">Одобрено</span>
                                    }
                                    else
                                    {
                                        <span class="admin-badge admin-badge--status-pending" data-i18n="admin.status.pending.approval">Чака одобрение</span>
                                    }
                                </td>
                                <td>
                                    <div class="groove-list-actions">
                                        <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id" class="groove-button groove-button-paper">
                                            <i class="bi bi-eye"></i> <span data-i18n="common.preview">Преглед</span>
                                        </a>
                                        <a asp-controller="Events" asp-action="Edit" asp-route-id="@ev.Id" class="groove-button groove-button-paper">
                                            <i class="bi bi-pencil"></i> <span data-i18n="common.edit">Редакция</span>
                                        </a>
                                        <a asp-controller="Tickets" asp-action="Manage" asp-route-id="@ev.Id" class="groove-button groove-button-paper">
                                            <i class="bi bi-ticket-perforated"></i> <span data-i18n="admin.tickets">Билети</span>
                                        </a>
                                        <a asp-controller="Events" asp-action="Delete" asp-route-id="@ev.Id" class="groove-button groove-button-paper">
                                            <i class="bi bi-trash"></i> <span data-i18n="common.delete">Изтрий</span>
                                        </a>
                                        @if (ev.HasPendingChanges)
                                        {
                                            <a asp-action="EventChange" asp-route-id="@ev.Id" class="groove-button groove-button-paper">
                                                <i class="bi bi-file-earmark-diff"></i> <span data-i18n="admin.status.changes">Промени</span>
                                            </a>
                                        }
                                        <form asp-action="ApproveEvent" asp-route-id="@ev.Id" method="post">
                                            @Html.AntiForgeryToken()
                                            @if (ev.HasPendingChanges)
                                            {
                                                <button class="groove-button groove-button-dark" type="submit">
                                                    <i class="bi bi-check-circle"></i> <span data-i18n="admin.action.approve.changes">Одобри промени</span>
                                                </button>
                                            }
                                            else if (ev.IsApproved)
                                            {
                                                <button class="groove-button groove-button-paper" type="submit">
                                                    <i class="bi bi-pause-circle"></i> <span data-i18n="admin.action.unapprove">Свали одобрение</span>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="groove-button groove-button-dark" type="submit">
                                                    <i class="bi bi-check-circle"></i> <span data-i18n="common.approve">Одобри</span>
                                                </button>
                                            }
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
