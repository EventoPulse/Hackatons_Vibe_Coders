@model AdminTransactionsViewModel
@{
    ViewData["Title"] = "Транзакции";
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-yellow" data-i18n="admin.kicker.finance">Финанси</span>
            <h1 data-i18n-html="admin.transactions.title">Платежни <span>транзакции</span>.</h1>
            <p data-i18n="admin.transactions.desc">Преглед на извършените демонстрационни плащания и общия приход от платените поръчки.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> <span data-i18n="common.back.admin">Към админ</span>
            </a>
        </div>
    </div>

    <div class="groove-alert groove-alert-info mb-4">
        <strong data-i18n="admin.total.revenue">Общ приход:</strong> @Model.TotalRevenue.ToString("0.00") <span data-i18n="currency.bgn">лв.</span>
    </div>

    @if (Model.Transactions.Count == 0)
    {
        <div class="groove-empty-card">
            <i class="bi bi-receipt"></i>
            <h2 class="groove-panel-title" data-i18n-html="admin.transactions.empty.title">Няма <span>транзакции</span>.</h2>
        </div>
    }
    else
    {
        <div class="groove-table-card">
            <div class="groove-table-wrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th data-i18n="admin.table.user">Потребител</th>
                            <th data-i18n="admin.table.email">Имейл</th>
                            <th data-i18n="admin.table.amount">Сума</th>
                            <th data-i18n="admin.table.tickets">Билети</th>
                            <th data-i18n="admin.table.status">Статус</th>
                            <th data-i18n="admin.table.date">Дата</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.Transactions)
                        {
                            var badgeClass = t.Status switch
                            {
                                GlobalConstants.TransactionStatuses.Paid => "admin-badge--status-paid",
                                GlobalConstants.TransactionStatuses.Pending => "admin-badge--status-pending",
                                GlobalConstants.TransactionStatuses.Failed => "admin-badge--status-danger",
                                GlobalConstants.TransactionStatuses.Cancelled => "admin-badge--status-neutral",
                                GlobalConstants.TransactionStatuses.Refunded => "admin-badge--status-neutral",
                                _ => "admin-badge--status-neutral",
                            };
                            var statusKey = t.Status switch
                            {
                                GlobalConstants.TransactionStatuses.Paid => "transaction.status.paid",
                                GlobalConstants.TransactionStatuses.Pending => "transaction.status.pending",
                                GlobalConstants.TransactionStatuses.Failed => "transaction.status.failed",
                                GlobalConstants.TransactionStatuses.Cancelled => "transaction.status.cancelled",
                                GlobalConstants.TransactionStatuses.Refunded => "transaction.status.refunded",
                                _ => "transaction.status.unknown",
                            };

                            <tr>
                                <td><strong>@t.UserName</strong></td>
                                <td>@t.Email</td>
                                <td>@t.TotalAmount.ToString("0.00") <span data-i18n="currency.bgn">лв.</span></td>
                                <td>@t.TicketCount</td>
                                <td><span class="admin-badge @badgeClass" data-i18n="@statusKey">@t.Status.ToTransactionStatusDisplay()</span></td>
                                <td>@t.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
