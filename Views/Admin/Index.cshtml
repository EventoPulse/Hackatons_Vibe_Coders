@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Админ";
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-yellow" data-i18n="admin.kicker.control">Контрол</span>
            <h1 data-i18n-html="admin.dashboard.title">Админ <span>център</span>.</h1>
            <p data-i18n="admin.dashboard.desc">
                Оттук управляваш роли, кандидатури, събития, публикации, билети и транзакции в Evento.
            </p>
        </div>
        <div class="groove-page-actions">
            <a asp-controller="Account" asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-person-circle"></i> <span data-i18n="org.myprofile">Моят профил</span>
            </a>
            <a asp-controller="Tickets" asp-action="Validate" class="groove-button groove-button-dark">
                <i class="bi bi-qr-code-scan"></i> <span data-i18n="nav.validate">Валидиране</span>
            </a>
        </div>
    </div>

    <div class="groove-stat-grid">
        <article class="groove-stat-card">
            <span data-i18n="admin.users">Потребители</span>
            <strong>@Model.UsersCount</strong>
        </article>
        <article class="groove-stat-card">
            <span data-i18n="admin.organizers">Организатори</span>
            <strong>@Model.OrganizersCount</strong>
            @if (Model.PendingOrganizersCount > 0)
            {
                <div class="mt-2">
                    <span class="admin-badge admin-badge--status-pending">
                        @Model.PendingOrganizersCount <span data-i18n="admin.badge.pending">чакащи</span>
                    </span>
                </div>
            }
        </article>
        <article class="groove-stat-card">
            <span data-i18n="admin.events">Събития</span>
            <strong>@Model.EventsCount</strong>
            @if (Model.PendingEventsCount > 0)
            {
                <div class="mt-2">
                    <span class="admin-badge admin-badge--status-pending">
                        @Model.PendingEventsCount <span data-i18n="admin.badge.for.review">за преглед</span>
                    </span>
                </div>
            }
        </article>
    </div>

    <section class="groove-page-section">
        <div class="groove-section-bar">
            <div>
                <span class="groove-kicker" data-i18n="admin.quick.actions">Бързи действия</span>
                <h2 data-i18n-html="admin.all.panels">Всички <span>админ панели</span>.</h2>
            </div>
        </div>

        <div class="groove-mini-grid">
            <a asp-action="Users" class="groove-paper-card admin-action-card">
                <span class="groove-kicker" data-i18n="admin.kicker.roles">Роли</span>
                <h3 class="mt-2" data-i18n="admin.users">Потребители</h3>
                <p data-i18n="admin.users.card.desc">Смяна на роли и редакция на акаунти.</p>
                <span class="admin-action-card__cta" data-i18n="common.open">Отвори</span>
            </a>
            <a asp-action="Organizers" class="groove-paper-card admin-action-card">
                <span class="groove-kicker" data-i18n="admin.kicker.applications">Кандидатури</span>
                <h3 class="mt-2" data-i18n="admin.organizers">Организатори</h3>
                <p data-i18n="admin.organizers.card.desc">Преглед и одобряване на нови организатори.</p>
                <span class="admin-action-card__cta" data-i18n="common.open">Отвори</span>
            </a>
            <a asp-action="Events" class="groove-paper-card admin-action-card">
                <span class="groove-kicker" data-i18n="admin.kicker.content">Съдържание</span>
                <h3 class="mt-2" data-i18n="admin.events">Събития</h3>
                <p data-i18n="admin.events.card.desc">Одобряване и управление на публикуваните събития.</p>
                <span class="admin-action-card__cta" data-i18n="common.open">Отвори</span>
            </a>
            <a asp-action="Posts" class="groove-paper-card admin-action-card">
                <span class="groove-kicker" data-i18n="admin.kicker.content">Съдържание</span>
                <h3 class="mt-2" data-i18n="admin.posts">Публикации</h3>
                <p data-i18n="admin.posts.card.desc">Преглед на постовете и тяхната активност.</p>
                <span class="admin-action-card__cta" data-i18n="common.open">Отвори</span>
            </a>
            <a asp-action="Tickets" class="groove-paper-card admin-action-card">
                <span class="groove-kicker" data-i18n="admin.kicker.sales">Продажби</span>
                <h3 class="mt-2" data-i18n="admin.tickets">Билети</h3>
                <p data-i18n="admin.tickets.card.desc">Следене на продадени, използвани и активни билети.</p>
                <span class="admin-action-card__cta" data-i18n="common.open">Отвори</span>
            </a>
            <a asp-action="Transactions" class="groove-paper-card admin-action-card">
                <span class="groove-kicker" data-i18n="admin.kicker.finance">Финанси</span>
                <h3 class="mt-2" data-i18n="admin.transactions">Транзакции</h3>
                <p data-i18n="admin.transactions.card.desc">Списък с плащания и обобщение на приходите.</p>
                <span class="admin-action-card__cta" data-i18n="common.open">Отвори</span>
            </a>
        </div>
    </section>

    @if (Model.RecentPosts.Count > 0)
    {
        <section class="groove-page-section">
            <div class="groove-section-bar">
                <div>
                    <span class="groove-kicker" data-i18n="admin.activity">Активност</span>
                    <h2 data-i18n-html="admin.latest.posts">Последни <span>публикации</span>.</h2>
                </div>
            </div>

            <div class="row row-cols-1 row-cols-sm-2 row-cols-xl-3 g-3">
                @foreach (var post in Model.RecentPosts)
                {
                    <div class="col"><partial name="_PostCard" model="post" /></div>
                }
            </div>
        </section>
    }
</section>
