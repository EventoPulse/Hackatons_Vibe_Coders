@model IReadOnlyList<PostCardViewModel>
@{
    ViewData["Title"] = "Публикации";
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-red" data-i18n="nav.feed">Поток</span>
            <h1 data-i18n-html="admin.posts.title">Админ преглед на <span>публикациите</span>.</h1>
            <p data-i18n="admin.posts.desc">Виж съдържанието, активността и бързо премахвай неподходящи публикации.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> <span data-i18n="common.back.admin">Към админ</span>
            </a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="groove-empty-card">
            <i class="bi bi-chat-square-text"></i>
            <h2 class="groove-panel-title" data-i18n-html="admin.posts.empty.title">Няма <span>публикации</span>.</h2>
        </div>
    }
    else
    {
        <div class="groove-table-card">
            <div class="groove-table-wrap">
                <table class="table">
                    <thead>
                        <tr>
                            <th data-i18n="admin.table.organizer">Организатор</th>
                            <th data-i18n="admin.table.content">Съдържание</th>
                            <th data-i18n="admin.table.related.event">Свързано събитие</th>
                            <th data-i18n="admin.table.published">Публикувана</th>
                            <th><i class="bi bi-heart"></i></th>
                            <th><i class="bi bi-chat"></i></th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var post in Model)
                        {
                            var preview = post.Content.Length > 80 ? post.Content[..80] + "..." : post.Content;

                            <tr>
                                <td><strong>@post.OrganizerName</strong></td>
                                <td>@preview</td>
                                <td>
                                    @if (post.EventId.HasValue)
                                    {
                                        <a asp-controller="Events" asp-action="Details" asp-route-id="@post.EventId">@post.EventTitle</a>
                                    }
                                    else
                                    {
                                        <text>—</text>
                                    }
                                </td>
                                <td>@post.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@post.LikesCount</td>
                                <td>@post.CommentsCount</td>
                                <td>
                                    <div class="groove-list-actions">
                                        <a asp-controller="Posts" asp-action="Details" asp-route-id="@post.Id" class="groove-button groove-button-paper">
                                            <i class="bi bi-eye"></i> <span data-i18n="common.preview">Преглед</span>
                                        </a>
                                        <a asp-controller="Posts" asp-action="Edit" asp-route-id="@post.Id" class="groove-button groove-button-paper">
                                            <i class="bi bi-pencil"></i> <span data-i18n="common.edit">Редакция</span>
                                        </a>
                                        <form asp-action="DeletePost" asp-route-id="@post.Id" method="post">
                                            @Html.AntiForgeryToken()
                                            <button class="groove-button groove-button-dark" type="submit" data-confirm-key="admin.posts.delete.confirm">
                                                <i class="bi bi-trash"></i> <span data-i18n="common.delete">Изтрий</span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
