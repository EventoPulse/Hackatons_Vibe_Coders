@model IEnumerable<EventCardViewModel>

@foreach (var ev in Model)
{
    <div class="evt-grid__cell"
         data-event-id="@ev.Id"
         data-event-title="@ev.Title"
         data-event-city="@ev.City"
         data-event-address="@ev.Address"
         data-event-genre="@ev.Genre"
         data-event-start="@ev.StartTime.ToString("O")"
         data-event-free="@ev.IsFreeEvent.ToString().ToLowerInvariant()">
        <partial name="_EventCard" model="ev" />
    </div>
}
