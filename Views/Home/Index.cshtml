@model EventsIndexViewModel
@using System.Text.Json
@using System.Text.Json.Serialization
@{
    ViewData["Title"] = "Начало";
    var hasRealEvents = Model.Events.Count > 0;
    var hasRealMapPins = Model.MapMarkers.Count > 0;

    var mapJsonOptions = new JsonSerializerOptions(JsonSerializerDefaults.Web);
    mapJsonOptions.Converters.Add(new JsonStringEnumConverter());
    var dataPayload = new
    {
        markers = Model.MapMarkers.Select(m => new
        {
            eventId = m.EventId,
            title = m.Title,
            city = m.City,
            address = m.Address,
            startTime = m.StartTime,
            genre = m.Genre.ToString(),
            imageUrl = m.ImageUrl,
            organizerName = m.OrganizerName,
            lat = m.Lat,
            lng = m.Lng,
            isApproximate = m.IsApproximate
        })
    };
    var dataJson = JsonSerializer.Serialize(dataPayload, mapJsonOptions);
    var visibleCityCount = Model.MapMarkers.Select(p => p.City).Distinct().Count();
    var trendingEvents = Model.TrendingEvents.Count > 0
        ? Model.TrendingEvents.Take(4).ToList()
        : Model.Events
            .OrderByDescending(e => e.GoingCount * 2 + e.InterestedCount + e.LikesCount + e.CommentsCount + e.SavesCount)
            .ThenBy(e => e.StartTime)
            .Take(4)
            .ToList();
}

@section Scripts {
    <script id="home-events-data" type="application/json">@Html.Raw(dataJson)</script>
    <partial name="_GoogleMapsLoader" />
    <script src="~/js/home-map.js" asp-append-version="true"></script>
}

<div class="groove-home">
    <div class="groove-marquee" aria-hidden="true">
        <div>
            <span data-i18n="marquee.live">★ Живи нощи</span><span data-i18n="marquee.diary">★ Дневник</span><span data-i18n="marquee.map">★ Карта на България</span><span data-i18n="marquee.tickets">★ Свежи билети</span><span>★ Техно</span><span>★ House</span><span>★ Jazz</span><span data-i18n="marquee.nearme">★ Около мен</span>
            <span data-i18n="marquee.live">★ Живи нощи</span><span data-i18n="marquee.diary">★ Дневник</span><span data-i18n="marquee.map">★ Карта на България</span><span data-i18n="marquee.tickets">★ Свежи билети</span><span>★ Техно</span><span>★ House</span><span>★ Jazz</span><span data-i18n="marquee.nearme">★ Около мен</span>
        </div>
    </div>

    <section class="groove-hero">
        <div class="groove-hero__copy">
            <div class="groove-stamp-row">
                <span class="groove-stamp groove-stamp-teal" data-i18n="home.stamp">Evento</span>
                <span class="groove-hand-note" data-i18n="home.live">на живо</span>
            </div>
            <h1 data-i18n-html="home.hero.h1">Дневник за най-<span>шумните</span> нощи в България.</h1>
            <p data-i18n="home.hero.p">
                Evento е част скрапбук, част карта, част бюро за събития. Организаторите движат сцената,
                слушателите намират точната вечер, а всеки град получава своите карфици.
            </p>

            <form id="home-smart-search-form" class="groove-smart-search" autocomplete="off">
                @Html.AntiForgeryToken()
                <label class="groove-smart-search__field" for="home-smart-search-input">
                    <i class="bi bi-stars groove-smart-search__icon" aria-hidden="true"></i>
                    <input id="home-smart-search-input" type="text" name="q"
                           data-i18n-placeholder="home.search.placeholder"
                           placeholder="техно тази вечер в София · джаз през уикенда · около мен" />
                </label>
                <button class="groove-button groove-button-red groove-smart-search__submit" type="submit">
                    <i class="bi bi-stars"></i> <span data-i18n="home.search.btn">Smart търсене</span>
                </button>
                <button id="home-smart-clear" class="groove-button groove-button-paper groove-smart-search__clear" type="button" data-i18n="home.clear">
                    Изчисти
                </button>
                <div class="groove-smart-search__status"><span id="home-search-status"></span></div>
            </form>

            <div class="modern-search-chips" aria-label="Бързи филтри" data-i18n-aria-label="home.filters.aria">
                <a asp-action="Index" asp-route-dateFrom="@DateTime.UtcNow.ToString("yyyy-MM-dd")" data-i18n="home.chip.today">Днес</a>
                <a asp-action="Index" asp-route-dateFrom="@DateTime.UtcNow.AddDays(2).ToString("yyyy-MM-dd")" data-i18n="home.chip.weekend">Този уикенд</a>
                <a asp-action="Index" asp-route-search="concert" data-i18n="home.chip.concerts">Концерти</a>
                <a asp-action="Index" asp-route-search="theatre" data-i18n="home.chip.theatre">Театър</a>
                <a asp-action="Index" asp-route-search="festival" data-i18n="home.chip.festivals">Фестивали</a>
                <a asp-action="Index" asp-route-search="free" data-i18n="home.chip.free">Безплатни</a>
                <a asp-action="Index" asp-route-search="family" data-i18n="home.chip.family">Семейни</a>
            </div>

            <div class="groove-hero__actions">
                <a href="#event-map" class="groove-button groove-button-dark" data-i18n="home.viewmap">Виж картата</a>
                <a asp-controller="Posts" asp-action="Index" class="groove-button groove-button-paper" data-i18n="home.openfeed">Отвори потока</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Events" asp-action="Recommended" class="groove-button groove-button-paper" data-i18n="nav.recommended">Препоръчани</a>
                }
            </div>
            <div class="groove-hero__actions">
                <a href="#event-cards-grid" class="groove-button groove-button-dark" data-i18n="home.discover.events">Открий събития</a>
                <a asp-controller="Account" asp-action="Apply" class="groove-button groove-button-paper" data-i18n="home.become.organizer">Стани организатор</a>
            </div>
            @if (User.Identity?.IsAuthenticated != true)
            {
                <div class="groove-note mt-3">
                    <span data-i18n="home.login.cta">Влез, за да получаваш по-добри препоръки и да запазваш събития.</span>
                    <a asp-controller="Account" asp-action="Login" class="groove-link" data-i18n="home.login.register">Вход / Регистрация</a>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(Model.PreferredCity))
            {
                <p class="small text-muted mt-3"><span data-i18n="home.personal.city">Показваме ти повече събития около</span> @Model.PreferredCity.</p>
            }
            <div class="groove-stats">
                <span><strong>@Model.Events.Count</strong> <span data-i18n="home.stats.nights">записани нощи</span></span>
                <span><strong>@visibleCityCount</strong> <span data-i18n="home.stats.cities">града</span></span>
                <span><strong>@Model.MapMarkers.Count</strong> <span data-i18n="home.stats.pins">карфици</span></span>
            </div>
        </div>

        <div class="groove-hero__media">
            <div class="groove-photo-card">
                <img src="@Url.Content("~/img/groove/crowd-doodle.png")" alt="Публика на концерт" />
            </div>
            <img class="groove-cassette" src="@Url.Content("~/img/groove/cassette-doodle.png")" alt="" aria-hidden="true" />
        </div>
    </section>

    <section class="groove-section home-discovery-strip">
        <div class="groove-section-heading">
            <div>
                <span class="groove-stamp groove-stamp-yellow" data-i18n="home.quick.filters">Бързи филтри</span>
                <h2 data-i18n="home.quick.filters.title">Намери точната вечер по-бързо.</h2>
            </div>
        </div>
        <div class="modern-search-chips">
            <a asp-action="Index" asp-route-dateFrom="@DateTime.UtcNow.ToString("yyyy-MM-dd")" data-i18n="home.tonight">Тази вечер</a>
            <a asp-action="Index" asp-route-dateFrom="@DateTime.UtcNow.AddDays(((int)DayOfWeek.Saturday - (int)DateTime.UtcNow.DayOfWeek + 7) % 7).ToString("yyyy-MM-dd")" data-i18n="home.weekend">Този уикенд</a>
            <a asp-action="Index" asp-route-search="free" data-i18n="home.free">Безплатни</a>
            <a href="#event-map" data-i18n="home.near.me">Наблизо</a>
            <a asp-action="Index" asp-route-search="popular" data-i18n="home.popular">Популярни</a>
            <a asp-action="Index" asp-route-dateFrom="@DateTime.UtcNow.ToString("yyyy-MM-dd")" data-i18n="home.new">Нови</a>
            <a asp-action="Index" asp-route-genre="@((int)EventGenre.Electronic)">Electronic</a>
            <a asp-action="Index" asp-route-genre="@((int)EventGenre.HipHop)">Hip-Hop</a>
            <a asp-action="Index" asp-route-genre="@((int)EventGenre.Jazz)">Live Music</a>
            <a asp-action="Index" asp-route-genre="@((int)EventGenre.Folk)">Folk</a>
            <a asp-action="Index" asp-route-genre="@((int)EventGenre.Festival)">Festivals</a>
        </div>
    </section>

    <section class="groove-section home-discovery-grid">
        <div class="home-discovery-panel">
            <div class="groove-section-heading">
                <div>
                    <span class="groove-stamp groove-stamp-teal" data-i18n="home.tonight">Тази вечер</span>
                    <h2 data-i18n="home.tonight.title">Какво се случва днес.</h2>
                </div>
            </div>
            @if (Model.TonightEvents.Count == 0)
            {
                <div class="profile-empty-state"><i class="bi bi-moon-stars"></i><strong data-i18n="home.tonight.empty">Няма събития за тази вечер.</strong><a asp-action="Index" data-i18n="home.all.events">Разгледай всички събития</a></div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-lg-2 g-3">
                    @foreach (var ev in Model.TonightEvents.Take(4))
                    {
                        <div class="col"><partial name="_EventCard" model="ev" /></div>
                    }
                </div>
            }
        </div>
        <div class="home-discovery-panel">
            <div class="groove-section-heading">
                <div>
                    <span class="groove-stamp groove-stamp-red" data-i18n="home.weekend">Този уикенд</span>
                    <h2 data-i18n="home.weekend.title">План за събота и неделя.</h2>
                </div>
            </div>
            @if (Model.WeekendEvents.Count == 0)
            {
                <div class="profile-empty-state"><i class="bi bi-calendar-week"></i><strong data-i18n="home.weekend.empty">Няма събития за този уикенд.</strong><a asp-action="Index" data-i18n="home.all.events">Разгледай всички събития</a></div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-lg-2 g-3">
                    @foreach (var ev in Model.WeekendEvents.Take(4))
                    {
                        <div class="col"><partial name="_EventCard" model="ev" /></div>
                    }
                </div>
            }
        </div>
    </section>

    @if (Model.RecentlyViewedEvents.Count > 0)
    {
        <section class="groove-section">
            <div class="groove-section-heading">
                <div>
                    <span class="groove-stamp groove-stamp-teal" data-i18n="home.recently.viewed">Последно разглеждани</span>
                    <h2 data-i18n="home.continue.exploring">Продължи разглеждането.</h2>
                </div>
            </div>
            <div class="row row-cols-1 row-cols-md-3 g-3">
                @foreach (var ev in Model.RecentlyViewedEvents.Take(3))
                {
                    <div class="col"><partial name="_EventCard" model="ev" /></div>
                }
            </div>
        </section>
    }

    <section id="event-map" class="groove-section groove-map-section home-results-section">
        <div class="home-results-heading">
            <div>
                <span class="groove-stamp groove-stamp-teal" data-i18n="home.results.kicker">Зона с резултати</span>
                <h2 data-i18n="home.results.title">Резултати за следващото ти събитие</h2>
            </div>
            <div class="home-results-tools">
                <button type="button"><i class="bi bi-calendar3"></i> <span data-i18n="home.results.date">Дата</span></button>
                <button type="button"><i class="bi bi-crosshair"></i> <span data-i18n="home.results.distance">Разстояние</span></button>
            </div>
        </div>
        <div class="groove-map-copy">
            <span class="groove-stamp groove-stamp-teal" data-i18n="home.map.stamp">Картата</span>
            <h2><span id="home-event-count">@Model.MapMarkers.Count</span> <span data-i18n="home.map.pins">карфици,</span> <span>@visibleCityCount <span data-i18n="home.map.cities">града</span></span>.</h2>
            <p data-i18n="home.map.p">
                Когато организаторите добавят събития с координати, те се появяват тук на момента.
                Кликни върху карфица, за да видиш детайлите.
            </p>
            <button id="use-my-location" class="groove-link" type="button">
                <i class="bi bi-crosshair"></i> <span data-i18n="home.geo.btn">Покажи моето местоположение</span>
            </button>
            <div id="geo-status" class="small text-muted mt-1"></div>
        </div>
        <div class="groove-map-frame">
            <span class="groove-map-badge groove-map-badge-left" data-i18n="@(hasRealMapPins ? "home.map.live" : "home.map.empty")">@(hasRealMapPins ? "жива карта" : "празна карта")</span>
            <span class="groove-map-badge groove-map-badge-right">google maps</span>
            <div id="events-map" class="notranslate" translate="no" data-no-i18n="true">
                <div class="map-loading-state">
                    <i class="bi bi-map"></i>
                    <span data-i18n="home.map.loading">Картата се зарежда...</span>
                </div>
            </div>
            <div id="home-no-results" class="alert alert-warning mt-2" style="display:none;" data-i18n="home.noresults">Няма събития, отговарящи на търсенето.</div>
        </div>
        <aside class="home-results-list">
            <div class="home-results-list__head">
                <span class="groove-stamp groove-stamp-teal" data-i18n="home.trending.stamp">Най-нашумели</span>
                <h3 data-i18n="home.trending.title">Събития, които хората следят</h3>
            </div>
            <div class="home-results-list__toolbar">
                <button type="button" class="is-active" data-i18n="home.trending.tab.trend">Тренд</button>
                <button type="button" data-i18n="home.trending.tab.weekend">Този уикенд</button>
                <button type="button" data-i18n="home.trending.tab.nearby">Наблизо</button>
            </div>
            @foreach (var ev in trendingEvents)
            {
                var heat = ev.GoingCount * 2 + ev.InterestedCount + ev.LikesCount + ev.CommentsCount + ev.SavesCount;

                <article class="home-result-row home-result-row--trending" data-show-on-map="@ev.Id" tabindex="0">
                    <span class="home-result-row__media">
                        @if (!string.IsNullOrWhiteSpace(ev.ImageUrl))
                        {
                            <img src="@ev.ImageUrl" alt="@ev.Title" />
                        }
                        else
                        {
                            <span><i class="bi bi-calendar-event"></i></span>
                        }
                    </span>
                    <div class="home-result-row__body">
                        <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id">@ev.Title</a>
                        <small>@ev.City · @ev.StartTime.ToString("dd.MM HH:mm")</small>
                        <span class="home-result-row__meta">
                            <i class="bi bi-fire"></i>
                            @if (heat == 0)
                            {
                                <span data-i18n="home.trending.new">ново</span>
                            }
                            else
                            {
                                <span>@heat</span> <span data-i18n="home.trending.reactions">реакции</span>
                            }
                        </span>
                    </div>
                    <span class="home-result-row__heat">#@(trendingEvents.IndexOf(ev) + 1)</span>
                </article>
            }
        </aside>
    </section>

    @if (Model.PopularOrganizers.Count > 0)
    {
        <section class="groove-section">
            <div class="groove-section-heading">
                <div>
                    <span class="groove-stamp groove-stamp-yellow" data-i18n="home.popular.organizers">Популярни организатори</span>
                    <h2 data-i18n="home.popular.organizers.title">Официални страници, които движат сцената.</h2>
                </div>
            </div>
            <div class="home-organizer-grid">
                @foreach (var organizer in Model.PopularOrganizers)
                {
                    <article class="home-organizer-card">
                        @if (!string.IsNullOrWhiteSpace(organizer.AvatarImageUrl))
                        {
                            <img src="@organizer.AvatarImageUrl" alt="@organizer.DisplayName" />
                        }
                        else
                        {
                            <span>@organizer.DisplayName[..1].ToUpperInvariant()</span>
                        }
                        <div>
                            <strong>@organizer.DisplayName</strong>
                            <small>@organizer.City</small>
                            @if (!string.IsNullOrWhiteSpace(organizer.Tagline))
                            {
                                <p>@organizer.Tagline</p>
                            }
                            <a asp-controller="Profiles" asp-action="Details" asp-route-id="@organizer.OwnerId" class="groove-link">
                                @organizer.UpcomingEventsCount <span data-i18n="home.upcoming.events">предстоящи събития</span>
                            </a>
                        </div>
                    </article>
                }
            </div>
        </section>
    }

    @if (Model.PopularCities.Count > 0)
    {
        <section class="groove-section">
            <div class="groove-section-heading">
                <div>
                    <span class="groove-stamp groove-stamp-teal" data-i18n="home.popular.cities">Популярни градове</span>
                    <h2 data-i18n="home.popular.cities.title">Избери град и виж какво предстои.</h2>
                </div>
            </div>
            <div class="modern-search-chips">
                @foreach (var cityItem in Model.PopularCities)
                {
                    <a asp-action="Index" asp-route-city="@cityItem.Name">@cityItem.Name · @cityItem.EventsCount</a>
                }
            </div>
        </section>
    }

    <section class="groove-section home-how-grid">
        <article class="groove-table-card">
            <span class="groove-stamp groove-stamp-teal" data-i18n="home.how.title">Как работи</span>
            <ol class="home-steps">
                <li><strong data-i18n="home.how.discover">Открий събитие</strong></li>
                <li><strong data-i18n="home.how.save.buy">Запази или купи билет</strong></li>
                <li><strong data-i18n="home.how.follow">Последвай организатор и остани в течение</strong></li>
            </ol>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Preferences" asp-action="Index" class="groove-button groove-button-paper" data-i18n="account.preferences">Предпочитания</a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="groove-button groove-button-dark" data-i18n="home.login.register">Вход / Регистрация</a>
            }
        </article>
        <article class="groove-table-card">
            <span class="groove-stamp groove-stamp-red" data-i18n="home.organizer.cta.kicker">Организираш събития?</span>
            <h2 data-i18n="home.organizer.cta.title">Създай публична страница, публикувай събития и управлявай билети от едно място.</h2>
            <div class="groove-hero__actions">
                @if (User.IsInRole(GlobalConstants.Roles.Organizer) || User.IsInRole(GlobalConstants.Roles.Admin))
                {
                    <a asp-controller="Organizer" asp-action="Dashboard" class="groove-button groove-button-dark" data-i18n="nav.organizer.panel">Organizer Panel</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Apply" class="groove-button groove-button-dark" data-i18n="home.become.organizer">Стани организатор</a>
                }
                <a asp-controller="Posts" asp-action="Index" class="groove-button groove-button-paper" data-i18n="home.openfeed">Виж как работи</a>
            </div>
        </article>
    </section>

    <section class="groove-section">
        <div class="groove-section-heading">
            <div>
                <span class="groove-stamp groove-stamp-red" data-i18n="home.events.stamp">Бюро за събития</span>
                <h2 data-i18n="@(hasRealEvents ? "home.events.title" : "home.events.empty")">@(hasRealEvents ? "Събития" : "Все още няма публикувани събития")</h2>
            </div>
            @if (User.IsInRole(GlobalConstants.Roles.Organizer) || User.IsInRole(GlobalConstants.Roles.Admin))
            {
                <a asp-controller="Events" asp-action="Create" class="groove-link" data-i18n="home.events.create">Създай събитие</a>
            }
        </div>

        <form method="get" class="groove-filter">
            <input type="text" name="search" value="@Model.Search" placeholder="Търси по заглавие..." data-i18n-placeholder="home.filter.search" />
            <select name="city">
                <option value="" data-i18n="filter.allcities">Всички градове</option>
                @foreach (var c in Model.Cities)
                {
                    <option value="@c" selected="@(Model.City == c)">@c</option>
                }
            </select>
            <select name="genre">
                <option value="" data-i18n="filter.allgenres">Всички жанрове</option>
                @foreach (var g in Enum.GetValues<EventGenre>())
                {
                    <option value="@((int)g)" selected="@(Model.Genre == g)" data-i18n="genre.@g">@g.GetDisplayName()</option>
                }
            </select>
            <input type="date" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
            <button type="submit" data-i18n="home.filter.btn">Филтър</button>
            <a asp-action="Index" data-i18n="home.clear">Изчисти</a>
        </form>

        @if (hasRealEvents)
        {
            <div id="event-cards-grid" class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
                @foreach (var ev in Model.Events)
                {
                    <div class="col"
                         data-event-id="@ev.Id"
                         data-event-title="@ev.Title"
                         data-event-city="@ev.City"
                         data-event-address="@ev.Address"
                         data-event-genre="@ev.Genre">
                        <partial name="_EventCard" model="ev" />
                    </div>
                }
            </div>
        }
        else
        {
            <div class="groove-empty-state">
                <p data-i18n="home.events.emptytext">Все още няма публикувани събития. Когато организаторите добавят такива, те ще се появят тук.</p>
                @if (User.Identity?.IsAuthenticated == true && !User.IsInRole(GlobalConstants.Roles.Organizer) && !User.IsInRole(GlobalConstants.Roles.Admin))
                {
                    <a asp-controller="Account" asp-action="Apply" class="groove-link" data-i18n="home.events.apply">Кандидатствай за организатор</a>
                }
            </div>
        }
    </section>
</div>
