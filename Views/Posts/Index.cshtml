@model IReadOnlyList<PostCardViewModel>
@{
    ViewData["Title"] = "Поток";
    var hasPosts = Model.Count > 0;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var isSignedIn = User.Identity?.IsAuthenticated == true;
}

<section class="groove-feed-page">
    <div class="groove-feed-hero">
        <div>
            <span class="groove-stamp groove-stamp-teal">Потокът</span>
            <h1>Живият <span>дневник</span>.</h1>
            <p>Какво казват организаторите и слушателите точно сега.</p>
        </div>
        @if (User.IsInRole(GlobalConstants.Roles.Organizer) || User.IsInRole(GlobalConstants.Roles.Admin))
        {
            <a asp-action="Create" class="groove-button groove-button-dark">
                <i class="bi bi-plus-lg"></i> Нова публикация
            </a>
        }
    </div>

    @if (hasPosts)
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">
            @foreach (var post in Model)
            {
                <div class="col"><partial name="_PostCard" model="post" /></div>
            }
        </div>
    }
    else
    {
        <div class="groove-empty-state">
            <p>Все още няма публикации в потока. Когато организаторите публикуват, те ще се появят тук.</p>
            @if (User.IsInRole(GlobalConstants.Roles.Organizer) || User.IsInRole(GlobalConstants.Roles.Admin))
            {
                <a asp-action="Create" class="groove-link">Бъди първият с публикация</a>
            }
        </div>
    }
</section>
