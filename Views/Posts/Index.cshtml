@model FeedViewModel
@{
    ViewData["Title"] = "Feed";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var isSignedIn = User.Identity?.IsAuthenticated == true;
    var currentStoryInitial = string.IsNullOrWhiteSpace(Model.CurrentUserDisplayName)
        ? "?"
        : Model.CurrentUserDisplayName[..1].ToUpperInvariant();
}

<section class="groove-feed-page social-feed-page social-feed-page--stream">
    <header class="social-feed-topbar">
        <div>
            <span class="groove-stamp groove-stamp-teal">Feed</span>
            <h1>Latest from the scene.</h1>
        </div>
        @if (isSignedIn)
        {
            <a asp-controller="Account" asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-columns-gap"></i> Account overview
            </a>
        }
    </header>

    <section class="social-stories-strip" aria-label="Active stories">
        @if (isSignedIn)
        {
            <article class="social-story-card social-story-card--create">
                <form asp-controller="Stories" asp-action="Create" asp-route-returnUrl="@returnUrl" method="post" enctype="multipart/form-data" class="story-create-form">
                    @Html.AntiForgeryToken()
                    <label class="story-create-trigger" for="story-media-input" title="Create story">
                        <span class="story-create-avatar">
                            @if (!string.IsNullOrWhiteSpace(Model.CurrentUserProfileImageUrl))
                            {
                                <img src="@Model.CurrentUserProfileImageUrl" alt="@Model.CurrentUserDisplayName" />
                            }
                            else
                            {
                                <span>@currentStoryInitial</span>
                            }
                        </span>
                        <span class="social-story-card__plus"><i class="bi bi-plus-lg"></i></span>
                    </label>
                    <input id="story-media-input" class="story-create-input" type="file" name="MediaFile" accept="image/jpeg,image/png,image/gif,image/webp,video/mp4,video/webm,video/quicktime" />
                    <div class="story-create-fields">
                        <span class="story-create-file" data-i18n="story.empty">Add story</span>
                        <input type="text" name="Caption" placeholder="Caption" maxlength="280" data-i18n-placeholder="story.caption" />
                        <button type="submit" data-i18n="story.post">Post story</button>
                    </div>
                </form>
            </article>
        }

        @foreach (var story in Model.Stories)
        {
            <article class="social-story-card">
                <button type="button"
                        class="social-story-card__media social-story-open"
                        data-story-media="@story.MediaUrl"
                        data-story-type="@(story.MediaType == PostMediaType.Video ? "video" : "image")"
                        data-story-author="@story.AuthorName"
                        data-story-caption="@story.Caption"
                        data-story-profile="@Url.Action("Details", "Profiles", new { id = story.AuthorId })">
                    @if (story.MediaType == PostMediaType.Video)
                    {
                        <video muted loop playsinline preload="metadata">
                            <source src="@story.MediaUrl" />
                        </video>
                    }
                    else
                    {
                        <img src="@story.MediaUrl" alt="@story.AuthorName story" />
                    }
                </button>
                <div class="social-story-card__meta">
                    <strong data-story-author-label>@story.AuthorName</strong>
                    @if (!string.IsNullOrWhiteSpace(story.Caption))
                    {
                        <span data-story-caption-label>@story.Caption</span>
                    }
                </div>
            </article>
        }

        @if (!Model.Stories.Any() && !isSignedIn)
        {
            <div class="social-empty-inline">Sign in to follow people and see active stories.</div>
        }
    </section>

    <div id="story-viewer" class="story-viewer" hidden aria-hidden="true">
        <button type="button" class="story-viewer__backdrop" data-story-close aria-label="Close story"></button>
        <article class="story-viewer__dialog" role="dialog" aria-modal="true" aria-label="Story viewer">
            <button type="button" class="story-viewer__close" data-story-close aria-label="Close story">
                <i class="bi bi-x-lg"></i>
            </button>
            <div class="story-viewer__media">
                <img id="story-viewer-image" alt="" />
                <video id="story-viewer-video" controls playsinline></video>
            </div>
            <footer class="story-viewer__meta">
                <a id="story-viewer-profile" href="#"></a>
                <p id="story-viewer-caption"></p>
            </footer>
        </article>
    </div>

    <div class="social-feed-shell social-feed-shell--stream">
        <main class="social-feed-main">
            @if (Model.FriendsActivity.Any())
            {
                <section class="social-feed-section social-feed-section--stream">
                    <div class="social-section-heading social-section-heading--compact">
                        <div>
                            <span class="groove-kicker">Following</span>
                            <h2>People you follow.</h2>
                        </div>
                    </div>
                    <div class="social-post-list social-post-list--stream">
                        @foreach (var post in Model.FriendsActivity)
                        {
                            <partial name="_PostCard" model="post" />
                        }
                    </div>
                </section>
            }

            <section class="social-feed-section social-feed-section--stream">
                <div class="social-section-heading social-section-heading--compact">
                    <div>
                        <span class="groove-kicker">Posts</span>
                        <h2>Organizer updates and fresh posts.</h2>
                    </div>
                </div>
                @if (Model.OrganizerPosts.Any())
                {
                    <div class="social-post-list social-post-list--stream">
                        @foreach (var post in Model.OrganizerPosts)
                        {
                            <partial name="_PostCard" model="post" />
                        }
                    </div>
                }
                else
                {
                    <div class="social-empty-panel">
                        <i class="bi bi-journal-text"></i>
                        <span>No posts yet.</span>
                    </div>
                }
            </section>
        </main>

        <aside class="social-feed-aside social-feed-aside--overview">
            <section class="social-side-panel social-side-panel--quick">
                <div class="social-side-panel__head">
                    <span class="groove-kicker">Events</span>
                    <a asp-controller="Home" asp-action="Index" class="groove-link">All</a>
                </div>
                @foreach (var ev in Model.RecommendedEvents.Take(3))
                {
                    <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id" class="social-event-mini">
                        <span>@ev.StartTime.ToString("dd MMM")</span>
                        <strong>@ev.Title</strong>
                        <small>@ev.City</small>
                    </a>
                }
            </section>

            <section class="social-side-panel social-side-panel--quick">
                <div class="social-side-panel__head">
                    <span class="groove-kicker">Trending</span>
                    <a asp-controller="Events" asp-action="Recommended" class="groove-link">More</a>
                </div>
                @foreach (var ev in Model.TrendingEvents.Take(3))
                {
                    <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id" class="social-event-mini">
                        <span><i class="bi bi-fire"></i></span>
                        <strong>@ev.Title</strong>
                        <small>@ev.GoingCount going · @ev.InterestedCount interested</small>
                    </a>
                }
            </section>

            <section class="social-side-panel">
                <span class="groove-kicker">Suggested profiles</span>
                @foreach (var profile in Model.SuggestedProfiles.Take(5))
                {
                    var profileInitial = string.IsNullOrWhiteSpace(profile.DisplayName) ? "?" : profile.DisplayName[..1].ToUpperInvariant();
                    <article class="social-profile-row">
                        <a asp-controller="Profiles" asp-action="Details" asp-route-id="@profile.Id" class="social-profile-row__main">
                            @if (!string.IsNullOrWhiteSpace(profile.ProfileImageUrl))
                            {
                                <img src="@profile.ProfileImageUrl" alt="@profile.DisplayName" />
                            }
                            else
                            {
                                <span>@profileInitial</span>
                            }
                            <div>
                                <strong>@profile.DisplayName</strong>
                                <small>@(profile.IsOrganizer ? "Organizer" : "User") · @profile.FollowersCount followers</small>
                            </div>
                        </a>
                        @if (isSignedIn)
                        {
                            <form asp-controller="Profiles" asp-action="Follow" asp-route-id="@profile.Id" asp-route-returnUrl="@returnUrl" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-primary">Follow</button>
                            </form>
                        }
                    </article>
                }
            </section>
        </aside>
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            var input = document.getElementById('story-media-input');
            if (input) {
                var form = input.closest('.story-create-form');
                var label = form ? form.querySelector('.story-create-file') : null;
                input.addEventListener('change', function () {
                    var file = input.files && input.files[0];
                    if (!form) return;
                    form.classList.toggle('has-file', !!file);
                    if (label) {
                        label.textContent = file ? file.name : 'Add story';
                    }
                });
            }

            var viewer = document.getElementById('story-viewer');
            if (!viewer) return;

            var mediaWrap = viewer.querySelector('.story-viewer__media');
            var image = document.getElementById('story-viewer-image');
            var video = document.getElementById('story-viewer-video');
            var profile = document.getElementById('story-viewer-profile');
            var caption = document.getElementById('story-viewer-caption');
            var closeButtons = viewer.querySelectorAll('[data-story-close]');

            function closeStory() {
                viewer.hidden = true;
                viewer.setAttribute('aria-hidden', 'true');
                document.body.classList.remove('story-viewer-open');

                if (video) {
                    video.pause();
                    video.removeAttribute('src');
                    video.load();
                }

                if (image) {
                    image.removeAttribute('src');
                    image.removeAttribute('alt');
                }

                if (mediaWrap) {
                    mediaWrap.classList.remove('is-image', 'is-video');
                }
            }

            function openStory(trigger) {
                var storyUrl = trigger.getAttribute('data-story-media');
                if (!storyUrl || !mediaWrap || !image || !video || !profile || !caption) return;

                var card = trigger.closest('.social-story-card');
                var authorLabel = card ? card.querySelector('[data-story-author-label]') : null;
                var captionLabel = card ? card.querySelector('[data-story-caption-label]') : null;
                var author = authorLabel ? authorLabel.textContent.trim() : (trigger.getAttribute('data-story-author') || '');
                var text = captionLabel ? captionLabel.textContent.trim() : (trigger.getAttribute('data-story-caption') || '');
                var profileUrl = trigger.getAttribute('data-story-profile') || '#';
                var storyType = trigger.getAttribute('data-story-type') === 'video' ? 'video' : 'image';

                closeStory();

                profile.textContent = author;
                profile.href = profileUrl;
                caption.textContent = text;
                caption.hidden = !text;

                if (storyType === 'video') {
                    video.src = storyUrl;
                    mediaWrap.classList.add('is-video');
                    video.play().catch(function () { });
                } else {
                    image.src = storyUrl;
                    image.alt = author ? author + ' story' : 'Story';
                    mediaWrap.classList.add('is-image');
                }

                viewer.hidden = false;
                viewer.setAttribute('aria-hidden', 'false');
                document.body.classList.add('story-viewer-open');
            }

            document.querySelectorAll('.social-story-open').forEach(function (trigger) {
                trigger.addEventListener('click', function () {
                    openStory(trigger);
                });
            });

            closeButtons.forEach(function (button) {
                button.addEventListener('click', closeStory);
            });

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape' && !viewer.hidden) {
                    closeStory();
                }
            });
        })();
    </script>
}
