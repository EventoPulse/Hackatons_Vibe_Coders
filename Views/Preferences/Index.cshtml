@model PreferencesViewModel?
@{
    ViewData["Title"] = "Предпочитания";
}

<section class="evt-page-shell">
    <header class="evt-page-hero">
        <span class="evt-page-hero__kicker"><i class="bi bi-sliders"></i> Настройки</span>
        <h1>Лични <span>предпочитания</span>.</h1>
        <p>
            Използваме ги, за да подреждаме по-добре препоръчаните събития според твоя вкус.
        </p>
        <div class="evt-page-hero__cta">
            <a asp-action="Edit" class="evt-btn evt-btn-primary">
                <i class="bi bi-pencil"></i> Редактирай
            </a>
            <a asp-controller="Events" asp-action="Recommended" class="evt-btn evt-btn-ghost">
                <i class="bi bi-stars"></i> Препоръчани
            </a>
        </div>
    </header>

    @if (Model == null)
    {
        <div class="evt-page-empty">
            <i class="bi bi-sliders"></i>
            <h2>Още няма <span>запазени настройки</span>.</h2>
            <p>Добави любим жанр, град или разстояние, за да получаваш по-точни предложения.</p>
            <div class="evt-page-hero__cta">
                <a asp-action="Edit" class="evt-btn evt-btn-primary">
                    <i class="bi bi-plus-lg"></i> Задай предпочитания
                </a>
            </div>
        </div>
    }
    else
    {
        <article class="evt-page-card">
            <dl class="evt-page-data">
                <dt>Предпочитани жанрове</dt>
                <dd>
                    @if (Model.PreferredGenres != null && Model.PreferredGenres.Count > 0)
                    {
                        <div class="evt-genre-pills">
                            @foreach (var g in Model.PreferredGenres)
                            {
                                <span class="evt-genre-pill">@g.GetDisplayName()</span>
                            }
                        </div>
                    }
                    else
                    {
                        <span class="text-muted">Няма зададени</span>
                    }
                </dd>

                <dt>Предпочитан град</dt>
                <dd>@(string.IsNullOrWhiteSpace(Model.PreferredCity) ? "Няма зададен" : Model.PreferredCity)</dd>

                <dt>Минимална възраст</dt>
                <dd>@(Model.MinAge.HasValue ? Model.MinAge.Value.ToString() : "Без ограничение")</dd>

                <dt>Максимално разстояние</dt>
                <dd>@(Model.MaxDistanceKm.HasValue ? $"{Model.MaxDistanceKm.Value} км" : "Без ограничение")</dd>
            </dl>

            <form asp-action="Delete" method="post" class="evt-page-card__footer">
                @Html.AntiForgeryToken()
                <button class="evt-btn evt-btn-ghost" onclick="return confirm('Да изчистя ли всички предпочитания?')">
                    <i class="bi bi-x-circle"></i> Изчисти предпочитанията
                </button>
            </form>
        </article>
    }
</section>
