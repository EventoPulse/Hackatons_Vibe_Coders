@model EventsApp.ViewModels.Posts.PostCardViewModel

<div class="card h-100 shadow-sm post-card">
    @if (!string.IsNullOrWhiteSpace(Model.FirstImageUrl))
    {
        <img src="@Model.FirstImageUrl" class="card-img-top card-img-top-fixed" alt="post image" />
    }
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <strong>@Model.OrganizerName</strong>
            <small class="text-muted">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
        </div>
        @if (Model.EventId.HasValue)
        {
            <div class="mb-2">
                <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId" class="small">
                    <i class="bi bi-link-45deg"></i> @Model.EventTitle
                </a>
            </div>
        }
        <p class="card-text post-body flex-grow-1">
            @(Model.Content.Length > 200 ? Model.Content[..200] + "…" : Model.Content)
        </p>
        <div class="small text-muted mb-2">
            <span><i class="bi bi-heart"></i> @Model.LikesCount</span>
            &middot;
            <span><i class="bi bi-chat"></i> @Model.CommentsCount</span>
        </div>
        <a asp-controller="Posts" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm mt-auto">Open</a>
    </div>
</div>
