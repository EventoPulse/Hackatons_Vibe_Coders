@model EventsApp.ViewModels.Posts.PostCardViewModel
@{
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="card h-100 shadow-sm post-card">
    @if (!string.IsNullOrWhiteSpace(Model.FirstMediaUrl))
    {
        if (Model.FirstMediaType == EventsApp.Models.PostMediaType.Video)
        {
            <video class="card-img-top card-img-top-fixed bg-dark" controls preload="metadata" muted>
                <source src="@Model.FirstMediaUrl" />
            </video>
        }
        else
        {
            <img src="@Model.FirstMediaUrl" class="card-img-top card-img-top-fixed" alt="post image" />
        }
    }
    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <strong>@Model.OrganizerName</strong>
            <small class="text-muted">@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
        </div>
        @if (Model.EventId.HasValue)
        {
            <div class="mb-2">
                <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId" class="small">
                    <i class="bi bi-link-45deg"></i> @Model.EventTitle
                </a>
            </div>
        }
        <p class="card-text post-body flex-grow-1">
            @(Model.Content.Length > 200 ? Model.Content[..200] + "…" : Model.Content)
        </p>
        <div class="d-flex justify-content-between align-items-center mt-auto">
            <div class="d-flex align-items-center gap-2">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var likeAction = Model.CurrentUserLiked ? "Unlike" : "Like";
                    var btnClass = Model.CurrentUserLiked ? "btn-danger" : "btn-outline-danger";
                    var iconClass = Model.CurrentUserLiked ? "bi-heart-fill" : "bi-heart";
                    <form asp-controller="Posts" asp-action="@likeAction" asp-route-id="@Model.Id"
                          asp-route-returnUrl="@returnUrl" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm @btnClass" type="submit" title="@likeAction">
                            <i class="bi @iconClass"></i> @Model.LikesCount
                        </button>
                    </form>
                }
                else
                {
                    <span class="small text-muted"><i class="bi bi-heart"></i> @Model.LikesCount</span>
                }
                <span class="small text-muted"><i class="bi bi-chat"></i> @Model.CommentsCount</span>
            </div>
            <a asp-controller="Posts" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">Open</a>
        </div>
    </div>
</div>
