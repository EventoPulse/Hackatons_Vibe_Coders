@model EditProfileViewModel
@{
    ViewData["Title"] = "Редакция на профил";
}

<section class="groove-app-page groove-form-shell groove-form-shell-narrow">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-teal">Профил</span>
            <h1>Редакция на <span>акаунта</span>.</h1>
            <p>Обнови потребителското име, контактите и кратката си биография.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> Обратно към профила
            </a>
        </div>
    </div>

    <div class="groove-form-panel">
        <form asp-action="EditProfile" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="groove-form-grid">
                <div class="mb-3">
                    <label asp-for="UserName" class="form-label"></label>
                    <input asp-for="UserName" class="form-control" autocomplete="username" />
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" autocomplete="email" readonly />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
            </div>

            <div class="groove-form-grid">
                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label"></label>
                    <input asp-for="PhoneNumber" class="form-control" autocomplete="tel" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="ProfileImageUrl" class="form-label"></label>
                    <input asp-for="ProfileImageUrl" class="form-control" />
                    <span asp-validation-for="ProfileImageUrl" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Bio" class="form-label"></label>
                <textarea asp-for="Bio" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Bio" class="text-danger small"></span>
            </div>

            <div class="groove-form-actions">
                <button type="submit" class="groove-button groove-button-dark">
                    <i class="bi bi-check-lg"></i> Запази промените
                </button>
                <a asp-action="Index" class="groove-button groove-button-paper">Отказ</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
