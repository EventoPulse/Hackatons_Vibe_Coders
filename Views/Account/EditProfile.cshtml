@model EditProfileViewModel
@{
    ViewData["Title"] = "Edit Profile";
    var displayName = !string.IsNullOrWhiteSpace(Model.UserName)
        ? Model.UserName
        : (!string.IsNullOrWhiteSpace(Model.Email) ? Model.Email : "Account");
    var avatarInitial = !string.IsNullOrWhiteSpace(displayName)
        ? displayName[0].ToString().ToUpperInvariant()
        : "?";
}

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-1"><i class="bi bi-pencil-square"></i> Edit Profile</h1>
                <p class="text-muted mb-0">Update the account details shown in your profile overview.</p>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to Account
            </a>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-3 mb-4">
                    @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl))
                    {
                        <img src="@Model.ProfileImageUrl"
                             class="rounded-circle object-fit-cover flex-shrink-0"
                             style="width:96px;height:96px;"
                             alt="Profile image preview for @displayName" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center flex-shrink-0 fw-semibold fs-2"
                             style="width:96px;height:96px;">
                            @avatarInitial
                        </div>
                    }

                    <div>
                        <h2 class="h5 mb-1">@displayName</h2>
                        <div class="text-muted small">Email and account creation date are currently read-only.</div>
                    </div>
                </div>

                <form asp-action="EditProfile" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="UserName" class="form-label"></label>
                            <input asp-for="UserName" class="form-control" />
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" readonly />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CreatedAt" class="form-label"></label>
                            <input class="form-control" value="@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")" readonly />
                        </div>

                        <div class="col-12">
                            <label asp-for="ProfileImageUrl" class="form-label"></label>
                            <input asp-for="ProfileImageUrl" class="form-control" placeholder="https://example.com/avatar.jpg" />
                            <span asp-validation-for="ProfileImageUrl" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Bio" class="form-label"></label>
                            <textarea asp-for="Bio" class="form-control" rows="5" placeholder="Tell people a bit about yourself."></textarea>
                            <span asp-validation-for="Bio" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2-circle"></i> Save
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
