@model EventCreateEditViewModel
@{
    ViewData["Title"] = "Ново събитие";
}

<section class="groove-app-page groove-form-shell">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-teal">Събитие</span>
            <h1>Създай нова <span>вечер</span>.</h1>
            <p>Добави основните детайли за събитието, за да го публикуваш в каталога на GrooveOn.</p>
        </div>
        <div class="groove-page-actions">
            <a asp-controller="Home" asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-arrow-left"></i> Към началото
            </a>
        </div>
    </div>

    <div class="groove-form-panel">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" id="event-description" class="form-control" rows="4"></textarea>
                <div class="d-flex align-items-start gap-2 mt-2">
                    <button type="button" id="ai-generate-description" class="groove-button groove-button-paper">Генерирай описание с AI</button>
                    <div id="ai-description-status" class="form-text text-muted"></div>
                </div>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="groove-form-grid">
                <div class="mb-3">
                    <label asp-for="City" class="form-label"></label>
                    <input asp-for="City" class="form-control" />
                    <span asp-validation-for="City" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Address" class="form-label"></label>
                    <input asp-for="Address" class="form-control" />
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>
            </div>

            <div class="groove-form-grid">
                <div class="mb-3">
                    <label asp-for="StartTime" class="form-label"></label>
                    <input asp-for="StartTime" type="datetime-local" class="form-control"
                           value="@Model.StartTime.ToString("yyyy-MM-ddTHH:mm")" />
                    <span asp-validation-for="StartTime" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="EndTime" class="form-label"></label>
                    <input asp-for="EndTime" type="datetime-local" class="form-control"
                           value="@Model.EndTime.ToString("yyyy-MM-ddTHH:mm")" />
                    <span asp-validation-for="EndTime" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Genre" class="form-label"></label>
                <select asp-for="Genre" asp-items="Html.GetEnumSelectList<EventGenre>()" class="form-select"></select>
                <span asp-validation-for="Genre" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ImageUrl" class="form-label"></label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                <span asp-validation-for="ImageUrl" class="text-danger small"></span>
            </div>

            @if (Model.CanEditApproval)
            {
                <div class="mb-3 form-check">
                    <input asp-for="IsApproved" class="form-check-input" type="checkbox" />
                    <label asp-for="IsApproved" class="form-check-label"></label>
                </div>
            }

            <div class="groove-form-actions">
                <button type="submit" class="groove-button groove-button-dark">
                    <i class="bi bi-check-lg"></i> Създай
                </button>
                <a asp-controller="Home" asp-action="Index" class="groove-button groove-button-paper">Отказ</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    @{
        var antiforgery = Html.AntiForgeryToken();
    }
    @antiforgery

    <script>
        (function () {
            var btn = document.getElementById('ai-generate-description');
            var ta = document.getElementById('event-description');
            var status = document.getElementById('ai-description-status');
            if (!btn || !ta) return;

            function val(name) {
                var el = document.querySelector('[name="' + name + '"]');
                if (!el) return null;
                if (el.tagName === 'SELECT') {
                    var opt = el.options[el.selectedIndex];
                    return opt ? opt.text : el.value;
                }
                return el.value;
            }

            btn.addEventListener('click', async function () {
                var title = val('Title');
                if (!title || !title.trim()) {
                    status.textContent = 'Enter a title first.';
                    status.className = 'form-text text-danger';
                    return;
                }

                var token = document.querySelector('input[name="__RequestVerificationToken"]');
                if (!token) {
                    status.textContent = 'Security token missing - reload the page.';
                    status.className = 'form-text text-danger';
                    return;
                }

                var original = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Generating...';
                status.textContent = 'Asking AI...';
                status.className = 'form-text text-muted';

                try {
                    var resp = await fetch('/Events/GenerateDescription', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token.value,
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({
                            title: title,
                            city: val('City'),
                            genre: val('Genre'),
                            hints: ta.value
                        })
                    });

                    var data = await resp.json();
                    if (data.ok && data.description) {
                        ta.value = data.description;
                        status.textContent = 'AI generated a draft - feel free to edit before saving.';
                        status.className = 'form-text text-success';
                    } else {
                        status.textContent = data.error || 'AI did not return text.';
                        status.className = 'form-text text-danger';
                    }
                } catch (err) {
                    status.textContent = 'Request failed: ' + (err && err.message ? err.message : 'unknown error');
                    status.className = 'form-text text-danger';
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = original;
                }
            });
        })();
    </script>
}
