@model IReadOnlyList<EventCardViewModel>
@{
    ViewData["Title"] = "Препоръчани";
    var hasPrefs = (bool)(ViewBag.HasPreferences ?? false);
}

<section class="evt-page-shell">
    <header class="evt-page-hero">
        <span class="evt-page-hero__kicker"><i class="bi bi-stars"></i> <span data-i18n="rec.stamp">Подбор</span></span>
        <h1 data-i18n-html="rec.h1">Вечери, избрани <span>за теб</span>.</h1>
        <p data-i18n="rec.p">
            Тук събираме предстоящите събития, които най-добре пасват на твоите предпочитания.
            Ако още не си ги настроил, ще покажем всички одобрени предложения.
        </p>
        <div class="evt-page-hero__cta">
            <a asp-controller="Preferences" asp-action="Index" class="evt-btn evt-btn-ghost">
                <i class="bi bi-sliders"></i> <span data-i18n="rec.myprefs">Моите предпочитания</span>
            </a>
            <a asp-controller="Preferences" asp-action="Edit" class="evt-btn evt-btn-primary">
                <i class="bi bi-pencil"></i> <span data-i18n="rec.settings">Настрой препоръките</span>
            </a>
        </div>
    </header>

    @if (!hasPrefs)
    {
        <div class="evt-page-banner">
            <i class="bi bi-info-circle"></i>
            <div>
                <strong data-i18n="rec.no.prefs">Нямаш запазени предпочитания.</strong>
                <span data-i18n="rec.no.prefs.desc">Показваме всички предстоящи одобрени събития. Добави любим жанр, град или радиус, за да получаваш по-точни предложения.</span>
            </div>
        </div>
    }

    @if (Model.Count == 0)
    {
        <div class="evt-page-empty">
            <i class="bi bi-stars"></i>
            <h2 data-i18n-html="rec.empty.title">Още няма <span>точно попадение</span>.</h2>
            <p data-i18n="rec.empty.desc">
                Няма предстоящи събития, които да отговарят на сегашните ти настройки.
                Можеш да ги промениш или да разгледаш всички събития.
            </p>
            <div class="evt-page-hero__cta">
                <a asp-controller="Preferences" asp-action="Edit" class="evt-btn evt-btn-primary">
                    <i class="bi bi-sliders"></i> <span data-i18n="rec.change.prefs">Промени предпочитанията</span>
                </a>
                <a asp-controller="Home" asp-action="Index" class="evt-btn evt-btn-ghost">
                    <i class="bi bi-compass"></i> <span data-i18n="nav.home">Към началото</span>
                </a>
            </div>
        </div>
    }
    else
    {
        <section class="evt-page-section">
            <header class="evt-page-section__head">
                <span class="evt-page-section__kicker" data-i18n="rec.upcoming.kicker">Предстоящи предложения</span>
                <h2>@Model.Count <span>събития</span> за следващите дни.</h2>
            </header>

            <div class="evt-page-grid">
                @foreach (var ev in Model)
                {
                    <partial name="_EventCard" model="ev" />
                }
            </div>
        </section>
    }
</section>
