@model IReadOnlyList<EventCardViewModel>
@{
    ViewData["Title"] = "Препоръчани";
    var hasPrefs = (bool)(ViewBag.HasPreferences ?? false);
}

<section class="groove-app-page">
    <div class="groove-page-hero">
        <div class="groove-page-hero__copy">
            <span class="groove-stamp groove-stamp-teal" data-i18n="rec.stamp">Подбор</span>
            <h1 data-i18n-html="rec.h1">Вечери, избрани <span>за теб</span>.</h1>
            <p data-i18n="rec.p">
                Тук събираме предстоящите събития, които най-добре пасват на твоите предпочитания.
                Ако още не си ги настроил, ще покажем всички одобрени предложения.
            </p>
        </div>
        <div class="groove-page-actions">
            <a asp-controller="Preferences" asp-action="Index" class="groove-button groove-button-paper">
                <i class="bi bi-sliders"></i> <span data-i18n="rec.myprefs">Моите предпочитания</span>
            </a>
            <a asp-controller="Preferences" asp-action="Edit" class="groove-button groove-button-dark">
                <i class="bi bi-pencil"></i> <span data-i18n="rec.settings">Настрой препоръките</span>
            </a>
        </div>
    </div>

    @if (!hasPrefs)
    {
        <div class="groove-alert groove-alert-info mb-4">
            <strong data-i18n="rec.no.prefs">Нямаш запазени предпочитания.</strong>
            <span data-i18n="rec.no.prefs.desc">Показваме всички предстоящи одобрени събития. Добави любим жанр, град или радиус,
            за да получаваш по-точни предложения.</span>
        </div>
    }

    @if (Model.Count == 0)
    {
        <div class="groove-empty-card">
            <i class="bi bi-stars"></i>
            <h2 class="groove-panel-title" data-i18n-html="rec.empty.title">Още няма <span>точно попадение</span>.</h2>
            <p class="groove-panel-intro" data-i18n="rec.empty.desc">
                Няма предстоящи събития, които да отговарят на сегашните ти настройки.
                Можеш да ги промениш или да разгледаш всички събития.
            </p>
            <div class="groove-form-actions justify-content-center">
                <a asp-controller="Preferences" asp-action="Edit" class="groove-button groove-button-dark">
                    <i class="bi bi-sliders"></i> <span data-i18n="rec.change.prefs">Промени предпочитанията</span>
                </a>
                <a asp-controller="Home" asp-action="Index" class="groove-button groove-button-paper">
                    <i class="bi bi-compass"></i> <span data-i18n="nav.home">Към началото</span>
                </a>
            </div>
        </div>
    }
    else
    {
        <section class="groove-page-section">
            <div class="groove-section-bar">
                <div>
                    <span class="groove-kicker" data-i18n="rec.upcoming.kicker">Предстоящи предложения</span>
                    <h2>@Model.Count <span>събития</span> за следващите дни.</h2>
                </div>
            </div>

            <div class="row row-cols-1 row-cols-sm-2 row-cols-xl-3 g-3">
                @foreach (var ev in Model)
                {
                    <div class="col"><partial name="_EventCard" model="ev" /></div>
                }
            </div>
        </section>
    }
</section>
